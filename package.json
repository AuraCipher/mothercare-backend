{
  "name": "mcs-backend",
  "version": "1.0.0",
  "description": "Mother Care School Node.js Backend with Authentication",
  "main": "dist/server.js",
  "scripts": {
    "dev": "prisma generate && nodemon --watch src --watch server.ts --ext ts --exec \"npx ts-node server.ts\"",
    "build": "tsc",
    "start": "node dist/server.js",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "lint": "eslint src --ext .ts",
    "test:unit": "jest --testPathIgnorePatterns=/node_modules/ --testPathIgnorePatterns=/dist/ --testPathIgnorePatterns=integration\\.test",
    "test:integration": "jest --testPathPatterns=integration\\.test --testPathIgnorePatterns=e2e-flow",
    "test:e2e": "jest --testPathPatterns=e2e-flow\\.integration\\.test",
    "test:all": "bash scripts/test-all.sh",
    "benchmark:year-end": "npx ts-node scripts/benchmark-year-end.ts",
    "load-test": "npx ts-node scripts/load-test.ts",
    "load-test:suite": "bash scripts/load-test-suite.sh",
    "openapi:generate": "npx ts-node scripts/generate-openapi.ts",
    "backup:postgres": "npx ts-node scripts/backup-postgres-r2.ts",
    "seed:demo": "npx ts-node prisma/seed-demo-school.ts",
    "db:reset:demo": "prisma migrate reset --force --skip-seed && npm run seed:demo"
  },
  "prisma": {
    "seed": "npx ts-node prisma/seed.ts"
  },
  "keywords": [
    "nodejs",
    "typescript",
    "express",
    "prisma",
    "jwt",
    "authentication"
  ],
  "author": "MCS Development Team",
  "license": "MIT",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1083.0",
    "@prisma/client": "^5.10.0",
    "@sentry/node": "^10.65.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "@upstash/redis": "^1.38.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.79.2",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "express-rate-limit": "^8.5.2",
    "file-type": "^21.3.4",
    "firebase-admin": "^13.10.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "redis": "^4.6.13",
    "resend": "^6.17.2",
    "sharp": "^0.35.1",
    "socket.io": "^4.8.3",
    "uuid": "^14.0.0",
    "validator": "^13.11.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.2",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/express-rate-limit": "^5.1.3",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.11.17",
    "@types/redis": "^4.0.11",
    "@types/sharp": "^0.31.1",
    "@types/supertest": "^7.2.0",
    "@types/validator": "^13.11.8",
    "@typescript-eslint/eslint-plugin": "^8.32.0",
    "@typescript-eslint/parser": "^8.32.0",
    "eslint": "^8.56.0",
    "jest": "^30.4.2",
    "jest-junit": "^17.0.0",
    "jest-mock-extended": "^4.0.1",
    "nodemon": "^3.1.14",
    "prisma": "^5.10.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  }
}
