# ── Node Environment ──
NODE_ENV=development
APP_MODE=development
PORT=5000
HOST=127.0.0.1

# ── Database ──
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

# ── Redis (Upstash) ──
UPSTASH_REDIS_REST_URL="https://your-instance.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your_token"

# ── JWT ──
JWT_SECRET=your_super_secret_jwt_key_min_32_chars
JWT_EXPIRY=7d

# ── OTP ──

# ── App ──

# ── Notifications (optional) ──

# ── CORS ──
ALLOWED_ORIGINS=http://localhost:8080,http://localhost:5173,http://localhost:3000

# ── School Branch (Community) ──
# Default branch name for single-school auto-assignment in group creation.
# The seed script in prisma/seed.ts creates this branch on first run.
# Change this if you fork the app for a different school name.
DEFAULT_BRANCH_NAME=Mother Care Sohan
