# ── Node Environment ──
NODE_ENV=development
APP_MODE=development
PORT=5000
HOST=127.0.0.1

# ── Database ──
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

# ── Redis (Upstash) ──
UPSTASH_REDIS_REST_URL="https://your-instance.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your_token"
# TCP URL for BullMQ message queue (Upstash → Connect → Redis tab → rediss://…)
REDIS_URL="rediss://default:YOUR_TOKEN@your-instance.upstash.io:6379"
MESSAGE_QUEUE_CONCURRENCY=3

# ── JWT ──
JWT_SECRET=your_super_secret_jwt_key_min_32_chars
JWT_EXPIRY=7d

# ── App ──
FRONTEND_URL=https://mothercare.pk
APP_DOWNLOAD_URL=https://play.google.com/store/apps/details?id=com.mothercare.app

# ── Meta WhatsApp Cloud API ──
META_WHATSAPP_PHONE_NUMBER_ID=
META_WHATSAPP_BUSINESS_ACCOUNT_ID=
META_WHATSAPP_ACCESS_TOKEN=
META_WHATSAPP_API_VERSION=v21.0

# ── CORS ──
ALLOWED_ORIGINS=http://localhost:8080,http://localhost:5173,http://localhost:3000

# ── Public API URL (used in stored file URLs) ──
APP_URL=http://localhost:5000

# ── Cloudflare R2 ──
# When set, uploads go to mcs-documents; otherwise local backend/uploads/
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_DOCUMENTS_BUCKET=mcs-documents
R2_BACKUPS_BUCKET=mcs-backups
# Optional public CDN base (private bucket → leave empty, serve via /api/uploads/:id)
R2_PUBLIC_BASE_URL=

# ── Load testing (backend/scripts/load-test-suite.sh) ──
# Defaults match prisma/seed.ts. Use demo credentials if you ran npm run seed:demo.
# LOAD_TEST_URL=http://127.0.0.1:5000
# LOAD_TEST_IDENTIFIER=admin
# LOAD_TEST_PASSWORD=admin123
# LOAD_TEST_IDENTIFIER=demo_admin
# LOAD_TEST_PASSWORD=DemoAdmin@123

# ── School Branch (Community) ──
# Default branch name for single-school auto-assignment in group creation.
# The seed script in prisma/seed.ts creates this branch on first run.
# Change this if you fork the app for a different school name.
DEFAULT_BRANCH_NAME=Mother Care Sohan

# ── Mobile chat (Socket.IO + encrypted FCM) ──
# AES key derivation for FCM payloads — min 32 chars (falls back to JWT_SECRET if unset)
PUSH_MASTER_SECRET=
SOCKET_PATH=/socket.io
FCM_ENABLED=false
# Path to Firebase service account JSON, or inline JSON string
FIREBASE_SERVICE_ACCOUNT_PATH=
FIREBASE_SERVICE_ACCOUNT_JSON=
CHAT_QUEUE_CONCURRENCY=5
