# ─────────────────────────────────────────────────────────────────────────────
# Mother Care School — Backend Environment
# Copy to backend/.env and fill in values.
# Validated at boot by Zod in backend/src/config/env.ts — invalid config exits.
# Step-by-step setup: web/docs → /docs/api/environment
# ─────────────────────────────────────────────────────────────────────────────

# ═══════════════════════════════════════════════════════════════════════════════
# REQUIRED
# ═══════════════════════════════════════════════════════════════════════════════

NODE_ENV=development
# development | production | test

APP_MODE=development
# development = verbose logs + permissive CORS (any Origin header)
# production    = strict CORS via ALLOWED_ORIGINS

PORT=5000
HOST=0.0.0.0
# development + physical phone/emulator: keep 0.0.0.0 so LAN IP and 10.0.2.2 work.
# production behind reverse proxy: often 127.0.0.1 locally; proxy handles public traffic.

DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/mcs?schema=public"
# PostgreSQL connection string (must be a valid URL)

JWT_SECRET=your_super_secret_jwt_key_minimum_32_characters
# HS256 signing key — minimum 32 characters. Rotate on compromise.

# ═══════════════════════════════════════════════════════════════════════════════
# APPLICATION URLS
# ═══════════════════════════════════════════════════════════════════════════════

FRONTEND_URL=http://localhost:3000
# Used in: admin invitation links, WhatsApp credential template body

APP_URL=http://localhost:5000
# Public API base URL stored in file metadata / upload URLs

APP_DOWNLOAD_URL=https://play.google.com/store/apps/details?id=com.mothercare.app
# Play Store / App Store link included in WhatsApp credential templates

SCHOOL_NAME=Mother Care School
# Startup banner + invitation HTML template branding

DEFAULT_BRANCH_NAME=Mother Care Sohan
# Single-school auto-assignment label (seed creates this branch)

JWT_EXPIRY=7d
# Token lifetime — jsonwebtoken expiry string (e.g. 7d, 24h)

# ═══════════════════════════════════════════════════════════════════════════════
# CORS (required in production)
# ═══════════════════════════════════════════════════════════════════════════════

ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
# Comma-separated exact origins (scheme + host + port). No wildcards.
# Must include your web portal origin AND any mobile web origins.

# ═══════════════════════════════════════════════════════════════════════════════
# REDIS — JWT blacklist (REST) + BullMQ workers (TCP)
# ═══════════════════════════════════════════════════════════════════════════════

UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_rest_token
# Upstash Redis REST — JWT blacklist on logout (backend/src/lib/jwt.ts)
# If unset: blacklist check may fail closed on logout verification

REDIS_URL=rediss://default:YOUR_TOKEN@your-instance.upstash.io:6379
# TCP URL for BullMQ — message worker (WhatsApp) + chat worker (FCM)
# Upstash: Connect → Redis tab → copy rediss:// URL
# If unset: WhatsApp sends synchronously; no chat push worker; no Socket.IO Redis adapter

MESSAGE_QUEUE_CONCURRENCY=3
# BullMQ message worker parallelism (credential_send jobs)

CHAT_QUEUE_CONCURRENCY=5
# BullMQ chat worker parallelism (push fanout, system notifications)

# ═══════════════════════════════════════════════════════════════════════════════
# META WHATSAPP CLOUD API — credential delivery (production path)
# ═══════════════════════════════════════════════════════════════════════════════

META_WHATSAPP_PHONE_NUMBER_ID=
# Phone Number ID from Meta Business Suite → WhatsApp → API Setup

META_WHATSAPP_ACCESS_TOKEN=
# System user or permanent token with whatsapp_business_messaging permission

META_WHATSAPP_BUSINESS_ACCOUNT_ID=
# WABA ID — useful for template management in Meta dashboard (not read by send code)

META_WHATSAPP_API_VERSION=v21.0
# Graph API version — used in graph.facebook.com/{version}/{phoneNumberId}/messages

# Approved templates required (create in Meta Business Manager):
#   credential_send         — students
#   credential_send_teacher — teachers
#   credential_send_staff   — staff
# Body parameters: name, username, password, portal URL, app download URL

# ═══════════════════════════════════════════════════════════════════════════════
# RESEND — CEO admin invitation emails
# ═══════════════════════════════════════════════════════════════════════════════

RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@yourschool.pk
# Required for automatic CEO admin invitation emails (POST /admin/invitations).
# When unset, invitations still work — the API returns a copy-link with emailSent:false.
# Verify your sending domain in the Resend dashboard before production use.

# ═══════════════════════════════════════════════════════════════════════════════
# CLOUDFLARE R2 — file storage (optional; falls back to backend/uploads/)
# ═══════════════════════════════════════════════════════════════════════════════

R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_DOCUMENTS_BUCKET=mcs-documents
R2_BACKUPS_BUCKET=mcs-backups
R2_PUBLIC_BASE_URL=
# Optional CDN base. Leave empty to serve private files via GET /api/uploads/:id

# ═══════════════════════════════════════════════════════════════════════════════
# RATE LIMITS (per IP — tune under load)
# ═══════════════════════════════════════════════════════════════════════════════

RATE_LIMIT_PASSWORD_WINDOW_MS=60000
RATE_LIMIT_PASSWORD_MAX=5
# Admin password-set endpoints — increase max in high-traffic LAN deployments

RATE_LIMIT_UPLOAD_WINDOW_MS=60000
RATE_LIMIT_UPLOAD_MAX=20
# POST /api/upload — lower max if storage abuse is a concern

# ═══════════════════════════════════════════════════════════════════════════════
# MOBILE CHAT — Socket.IO + encrypted FCM push
# ═══════════════════════════════════════════════════════════════════════════════

SOCKET_PATH=/socket.io
# Socket.IO HTTP path — must match mobile/web client config

FCM_ENABLED=false
# Set true when Firebase credentials are configured

PUSH_MASTER_SECRET=
# AES key derivation for encrypted FCM payloads (min 32 chars)
# Falls back to JWT_SECRET if unset

FIREBASE_SERVICE_ACCOUNT_PATH=
# Path to Firebase service account JSON file on the server

FIREBASE_SERVICE_ACCOUNT_JSON=
# Inline JSON alternative to FIREBASE_SERVICE_ACCOUNT_PATH (one or the other)

# ═══════════════════════════════════════════════════════════════════════════════
# OBSERVABILITY
# ═══════════════════════════════════════════════════════════════════════════════

SENTRY_DSN=
# Sentry error tracking URL — initSentry() in backend/server.ts
# Captures unhandled 500s and worker failures when set

# ═══════════════════════════════════════════════════════════════════════════════
# LOAD TESTING (optional — backend/scripts/load-test-suite.sh)
# ═══════════════════════════════════════════════════════════════════════════════

# LOAD_TEST_URL=http://127.0.0.1:5000
# LOAD_TEST_IDENTIFIER=admin
# LOAD_TEST_PASSWORD=admin123
# LOAD_TEST_IDENTIFIER=demo_admin
# LOAD_TEST_PASSWORD=DemoAdmin@123
