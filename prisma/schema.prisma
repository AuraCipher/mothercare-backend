// Mother Care — School Management Platform
// Database Schema v2.0 — Academic Year System
// PostgreSQL + Prisma ORM

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ╔══════════════════════════════════════════════════════════════════╗
// ║                         ENUMERATIONS                            ║
// ╚══════════════════════════════════════════════════════════════════╝

enum Role {
  super_admin // Highest authority, full system access
  management // Administrative staff with assigned permissions
  teacher // Class/group instructors
  parent // Parent/student merged account
  student // Student login account
}

enum Gender {
  male
  female
  other
}

enum AccountStatus {
  active
  inactive
  suspended
}

// Branch-level roles for hierarchical access control
enum BranchRole {
  branch_admin // Principal — full branch management
  sub_admin // Vice-Principal / Deputy
  management // Accountant, Admin Staff
  teacher // Teaching staff
  parent // Parent representative
  canteen_staff // Canteen — daily sales only (assigned by admin)
  worker // Cleaners, guards, etc. — payroll + attendance, optional login
}

// Module access for branch staff (RBAC)
enum StaffModule {
  STUDENTS
  OPERATIONS
  TIMETABLE
  ATTENDANCE
  FEES
  RESULT
  CANTEEN
  STATIONARY
  EXPENSES
}

// Academic Year lifecycle: BUILD_STAGE → ACTIVE → ARCHIVED
enum AcademicYearStatus {
  BUILD_STAGE // Year being set up — only admins see it
  ACTIVE // Current operational year — everyone sees it
  ON_HOLD // Temporarily paused (e.g. summer break) — resume to ACTIVE
  ARCHIVED // Closed year — admins can still edit data
}

enum AcademicYearAuditAction {
  CREATED
  PUBLISHED
  ARCHIVED
  UNARCHIVED
  DELETED
  PAUSED
  RESUMED
}

// Year-end close / batch promotion state machine
enum PromotionStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  REVERSED
  FAILED
}

// Student lifecycle status
enum StudentStatus {
  ACTIVE
  GRADUATED
  WITHDRAWN
  TRANSFERRED
  SUSPENDED
  EXPELED
  DECEASED
}

enum ApiKeyType {
  publishable // Public: verified store / registered layout
  secret // Admin: bypass login, full CRUD
}

enum ExamStatus {
  DRAFT
  ACTIVE
}

enum ReportCardStatus {
  DRAFT
  PUBLISHED
}

enum CanteenPersonType {
  STUDENT
  TEACHER
  STAFF
}

enum CanteenSupplierPaymentDirection {
  WE_PAID_SUPPLIER
  SUPPLIER_PAID_US
}

enum CanteenSalePaymentType {
  CASH
  CREDIT
}

enum StationaryStockMovementType {
  STOCK_IN
  ADJUSTMENT
  STUDENT_ASSIGNED
}

enum StationarySupplierPaymentDirection {
  WE_PAID_SUPPLIER
  SUPPLIER_PAID_US
}

enum OutgoingPaymentType {
  PAYROLL
  UTILITY
  OTHER
}

enum OutgoingPaymentStatus {
  PAID
  VOID
}

enum OutgoingPaymentMethod {
  CASH
  CHEQUE
  BANK_TRANSFER
  ONLINE
}

enum PayrollPayeeType {
  TEACHER
  STAFF
}

enum PayrollPaymentKind {
  REGULAR
  EXTRA
}

enum ExpenseCategoryKind {
  UTILITY
  OTHER
}

enum BatchPromotionRunPhase {
  DRAFT
  SNAPSHOT_DONE
  APPLIED
  PUBLISHED
  FAILED
}

enum StudentCredentialTag {
  CRED_NONE
  CRED_CARRIED
  CRED_NEW
  CRED_RESEND
  NO_LOGIN
}

enum TenureEndReason {
  RESIGNED
  TERMINATED
  TRANSFERRED
  GRADUATED
  WITHDRAWN
  DECEASED
  LEAVE
  REJOINED
  OTHER
}

// ╔══════════════════════════════════════════════════════════════════╗
// ║                           USERS                                 ║
// ║  All credentials created by admin. No signup / forgot password. ║
// ╚══════════════════════════════════════════════════════════════════╝

model User {
  id               String        @id @default(uuid())
  schoolId         String?
  name             String
  username         String?       @unique
  email            String?       @unique
  phone            String?       @unique
  passwordHash     String
  role             Role          @default(parent)
  managementPerms  String[]      @default([])
  gender           Gender?
  dateOfBirth      DateTime?
  address          String?
  profilePhoto     String?
  profilePhotoId   String?       @unique
  profileFile      FileRecord?   @relation("UserProfilePhoto", fields: [profilePhotoId], references: [id])
  status           AccountStatus @default(active)
  isEmailVerified  Boolean       @default(false)
  isPhoneVerified  Boolean       @default(false)
  lastLoginAt      DateTime?
  lastSeen         DateTime?
  rememberMeToken  String?       @unique
  rememberMeExpiry DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  // Existing relations
  managementProfile   ManagementProfile?
  teacherProfile      TeacherProfile?
  staffProfile        StaffProfile?
  parentProfile       ParentProfile?
  subjectsAsHod       Subject[]               @relation("SubjectHOD")
  sentMessages        Message[]               @relation("SentMessages")
  notifications       NotificationRecipient[]
  deviceTokens        DeviceToken[]
  auditLogs           AuditLog[]
  groupMembers        GroupMember[]
  batchPromotions     BatchPromotion[]        @relation("PromotedByUser")
  batchPromotionRuns  BatchPromotionRun[]     @relation("BatchPromotionTriggeredBy")
  passwordResetTokens PasswordResetToken[]

  // New relations for Academic Year System
  branchMembers             BranchMember[]
  // Reverse relations for BranchMember.assignedBy and BranchMember.resignedInFavorOf
  assignedMembers           BranchMember[]         @relation("AssignedBy")
  resignedToMembers         BranchMember[]         @relation("ResignedInFavorOf")
  academicYearMembers       AcademicYearMember[]
  teacherAssignments        TeacherAssignment[]
  teacherAttendances        TeacherAttendance[]    @relation("TeacherAttendanceTeacher")
  academicYearSnapshots     AcademicYearSnapshot[] @relation("SnapshotTriggeredBy")
  timetableEntries          TimetableEntry[]       @relation("TimetableTeacher")
  uploadedFiles             FileRecord[]
  student                   Student?
  studentPerson             StudentPerson?
  createdStudents           Student[]              @relation("StudentCreatedBy")
  updatedStudents           Student[]              @relation("StudentUpdatedBy")
  credentialSends           CredentialSend[]
  markedAttendances         Attendance[]
  teacherAttendanceMarkedBy TeacherAttendance[]    @relation("TeacherAttendanceMarkedBy")
  studentStatusChanges      StudentStatusLog[]
  feeChangeLogs             FeeChangeLog[]
  recordedPayments          Payment[]              @relation("PaymentRecordedBy")
  revertedPayments          Payment[]              @relation("PaymentRevertedBy")
  recordedFamilyPayments    FamilyPayment[]
  createdFamilies           Family[]           @relation("FamilyCreatedBy")
  updatedFamilies           Family[]           @relation("FamilyUpdatedBy")
  familyChangeLogs          FamilyChangeLog[]
  enteredMarks              MarksEntry[]           @relation("MarksEnteredBy")
  canteenAccounts           CanteenAccount[]       @relation("CanteenAccountUser")
  canteenSalesRecorded      CanteenSale[]          @relation("CanteenSaleCreatedBy")
  canteenAccountPayments    CanteenAccountPayment[] @relation("CanteenAccountPaymentCreatedBy")
  canteenSupplierPayments   CanteenSupplierPayment[] @relation("CanteenSupplierPaymentCreatedBy")
  canteenRestockPurchases   CanteenRestockPurchase[] @relation("CanteenRestockCreatedBy")
  canteenAccountsCreated    CanteenAccount[]       @relation("CanteenAccountCreatedBy")
  stationaryStockMovements  StationaryStockMovement[] @relation("StationaryStockMovementCreatedBy")
  stationaryRecordsCreated  StudentStationaryRecord[] @relation("StudentStationaryRecordCreatedBy")
  stationarySupplierPayments StationarySupplierPayment[] @relation("StationarySupplierPaymentCreatedBy")
  stationaryRestockPurchases StationaryRestockPurchase[] @relation("StationaryRestockCreatedBy")
  staffAttendances           StaffAttendance[]           @relation("StaffAttendanceStaff")
  staffAttendanceMarkedBy    StaffAttendance[]           @relation("StaffAttendanceMarkedBy")
  payrollPaymentsReceived    PayrollPaymentDetail[]      @relation("PayrollPayee")
  outgoingPaymentsRecorded   BranchOutgoingPayment[]     @relation("OutgoingPaymentRecordedBy")
  outgoingPaymentsVoided     BranchOutgoingPayment[]     @relation("OutgoingPaymentVoidedBy")
  payrollBulkRunsRecorded    PayrollBulkRun[]            @relation("PayrollBulkRunRecordedBy")
  academicYearAuditsPerformed AcademicYearAuditLog[]     @relation("AcademicYearAuditPerformedBy")

  @@index([username])
  @@index([email])
  @@index([phone])
  @@index([role])
  @@index([status])
  @@map("users")
}

// ╔══════════════════════════════════════════════════════════════════╗
// ║                    FILE RECORD                                 ║
// ║  Universal file reference for profile photos, documents, etc.  ║
// ╚══════════════════════════════════════════════════════════════════╝

model FileRecord {
  id           String   @id @default(uuid())
  originalName String
  storagePath  String   @unique
  mimeType     String
  size         Int
  width        Int?
  height       Int?
  uploadedById String?
  entityType   String? // "student" | "teacher" — what entity this doc belongs to
  entityId     String? // UUID of the student or teacher profile
  createdAt    DateTime @default(now())

  uploader       User?    @relation(fields: [uploadedById], references: [id])
  profileUser    User?    @relation("UserProfilePhoto")
  profileStudent Student? @relation("StudentProfilePhoto")

  updatedAt DateTime @updatedAt

  @@index([entityType, entityId])
  @@map("file_records")
}

// ╔══════════════════════════════════════════════════════════════════╗
// ║                       SCHOOL / TENANT                           ║
// ║  Kept for backward compatibility (may be deprecated later).     ║
// ╚══════════════════════════════════════════════════════════════════╝

model School {
  id              String   @id @default(uuid())
  name            String
  address         String?
  phone           String?
  email           String?
  logoUrl         String?
  website         String?
  timezone        String   @default("Asia/Karachi")
  currency        String   @default("PKR")
  passingMarks    Float    @default(50.0)
  attendanceAlert Int      @default(75)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  createdById String?
  updatedById String?

  @@map("schools")
}

// ╔══════════════════════════════════════════════════════════════════╗
// ║                        BRANCH (Physical Campus)                 ║
// ║  A physical school campus or franchise location.               ║
// ║  Example: "Mother Care Sohan" (code: MCS-SOHAN)               ║
// ╚══════════════════════════════════════════════════════════════════╝

model Branch {
  id        String   @id @default(uuid())
  name      String   @unique
  code      String   @unique // Short code: "MCS-SOHAN"
  address   String?
  phone     String?
  email     String?
  logoUrl   String?
  isActive  Boolean  @default(true)
  teacherParentContactEnabled Boolean @default(false)
  teachersCanMarkAttendance   Boolean @default(true)
  teachersCanEnterMarks       Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  academicYears    AcademicYear[]
  studentPersons   StudentPerson[]
  branchMembers    BranchMember[]
  batchPromotionRuns BatchPromotionRun[]
  adminInvitations AdminInvitation[]
  canteenSuppliers         CanteenSupplier[]
  canteenProductCategories CanteenProductCategory[]
  canteenProducts          CanteenProduct[]
  canteenAccounts          CanteenAccount[]
  canteenSales             CanteenSale[]
  canteenRestockPurchases  CanteenRestockPurchase[]
  stationaryCategories     StationaryCategory[]
  stationarySuppliers      StationarySupplier[]
  stationaryProducts       StationaryProduct[]
  stationaryStockMovements StationaryStockMovement[]
  studentStationaryRecords StudentStationaryRecord[]
  stationaryRestockPurchases StationaryRestockPurchase[]
  branchExpenseCategories    BranchExpenseCategory[]
  utilityProviders           UtilityProvider[]
  branchOutgoingPayments     BranchOutgoingPayment[]
  payrollMonthBalances       PayrollMonthBalance[]
  payrollBulkRuns            PayrollBulkRun[]
  academicYearAuditLogs      AcademicYearAuditLog[]

  createdById String?
  updatedById String?

  @@map("branches")
}

// ╔══════════════════════════════════════════════════════════════════╗
// ║                   ACADEMIC CALENDAR                             ║
// ║  Shared reference: label ("2025-2026"), start/end dates.       ║
// ║  Decoupled from the container — multiple branches share the    ║
// ║  same calendar definition.                                     ║
// ╚══════════════════════════════════════════════════════════════════╝

model AcademicCalendar {
  id        String   @id @default(uuid())
  label     String   @unique // "2025-2026", "2026-2027"
  startDate DateTime
  endDate   DateTime
  isCurrent Boolean  @default(false) // Only one globally
  createdAt DateTime @default(now())

  academicYears AcademicYear[]

  updatedAt DateTime @updatedAt

  createdById String?
  updatedById String?

  @@map("academic_calendars")
}

// ╔══════════════════════════════════════════════════════════════════╗
// ║                      ACADEMIC YEAR                              ║
// ║  The core container — everything lives inside one.              ║
// ║  Lifecycle: BUILD_STAGE → ACTIVE → ARCHIVED                    ║
// ║  Exactly one ACTIVE per branch.                                 ║
// ╚══════════════════════════════════════════════════════════════════╝

model AcademicYear {
  id                     String             @id @default(uuid())
  branchId               String
  calendarId             String
  status                 AcademicYearStatus @default(BUILD_STAGE)
  previousAcademicYearId String? // Self-referencing FK for year chain
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt

  branch               Branch           @relation(fields: [branchId], references: [id], onDelete: Cascade)
  calendar             AcademicCalendar @relation(fields: [calendarId], references: [id])
  previousAcademicYear AcademicYear?    @relation("YearSequence", fields: [previousAcademicYearId], references: [id])
  nextAcademicYears    AcademicYear[]   @relation("YearSequence")

  members            AcademicYearMember[]
  groups             Group[]
  subjects           Subject[]
  teacherAssignments TeacherAssignment[]
  students           Student[]
  enrollments        Enrollment[]
  snapshots          AcademicYearSnapshot[] @relation("SourceAcademicYear")
  newSnapshots       AcademicYearSnapshot[] @relation("NewAcademicYear")
  announcements      Announcement[]
  timetables         Timetable[]
  attendances        Attendance[]
  teacherAttendances TeacherAttendance[]
  staffAttendances   StaffAttendance[]
  examSessions       ExamSession[]

  createdById   String?
  updatedById   String?
  feeStructures FeeStructure[]
  studentFees   StudentFee[]
  promotionRunsAsSource BatchPromotionRun[] @relation("PromotionSourceAy")
  promotionRunsAsTarget BatchPromotionRun[] @relation("PromotionTargetAy")
  teacherAySnapshots    TeacherAySnapshot[]
  stationaryRecords     StudentStationaryRecord[]
  auditLogs             AcademicYearAuditLog[]

  @@unique([branchId, calendarId])
  @@map("academic_years")
}

model AcademicYearAuditLog {
  id             String                  @id @default(uuid())
  academicYearId String
  branchId       String
  action         AcademicYearAuditAction
  fromStatus     AcademicYearStatus?
  toStatus       AcademicYearStatus?
  note           String?
  performedById  String?
  metadata       Json?
  createdAt      DateTime                @default(now())

  academicYear AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  branch       Branch       @relation(fields: [branchId], references: [id], onDelete: Cascade)
  performedBy  User?        @relation("AcademicYearAuditPerformedBy", fields: [performedById], references: [id], onDelete: SetNull)

  @@index([branchId, createdAt])
  @@index([academicYearId, createdAt])
  @@map("academic_year_audit_logs")
}

// ╔══════════════════════════════════════════════════════════════════╗
// ║                   ACADEMIC YEAR MEMBER                          ║
// ║  Links users to an academic year with a specific role.          ║
// ╚══════════════════════════════════════════════════════════════════╝

model AcademicYearMember {
  id             String @id @default(uuid())
  academicYearId String
  userId         String
  role           Role

  academicYear AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdById String?
  updatedById String?

  @@unique([academicYearId, userId])
  @@map("academic_year_members")
}

// ╔══════════════════════════════════════════════════════════════════╗
// ║                       BRANCH MEMBER                             ║
// ║  Links users to a branch (cross-year membership).               ║
// ╚══════════════════════════════════════════════════════════════════╝

model BranchMember {
  id                  String     @id @default(uuid())
  branchId            String
  userId              String
  role                BranchRole @default(teacher)
  isActive            Boolean    @default(true)
  keepTeacherRole     Boolean    @default(true)
  assignedById        String?
  resignedAt          DateTime?
  resignedInFavorOfId String?
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt

  branch            Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)
  user              User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignedBy        User?  @relation("AssignedBy", fields: [assignedById], references: [id])
  resignedInFavorOf User?  @relation("ResignedInFavorOf", fields: [resignedInFavorOfId], references: [id])

  createdById String?
  updatedById String?

  modulePermissions StaffModulePermission[]
  tenures           BranchTenure[]

  @@unique([branchId, userId])
  @@index([userId])
  @@map("branch_members")
}

model StaffModulePermission {
  id             String      @id @default(uuid())
  branchMemberId String
  module         StaffModule
  canCreate      Boolean     @default(false)
  canRead        Boolean     @default(true)
  canUpdate      Boolean     @default(false)
  canDelete      Boolean     @default(false)
  archivedCanRead    Boolean @default(false)
  archivedCanCreate  Boolean @default(false)
  archivedCanUpdate  Boolean @default(false)
  archivedCanDelete  Boolean @default(false)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  branchMember BranchMember @relation(fields: [branchMemberId], references: [id], onDelete: Cascade)

  @@unique([branchMemberId, module])
  @@index([branchMemberId])
  @@map("staff_module_permissions")
}

// Append-only join/leave/rejoin history for teachers & staff at a branch.
model BranchTenure {
  id               String           @id @default(uuid())
  branchMemberId   String
  sequence         Int
  joinedAt         DateTime
  leftAt           DateTime?
  endReason        TenureEndReason?
  notes            String?
  previousTenureId String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  createdById      String?

  branchMember   BranchMember  @relation(fields: [branchMemberId], references: [id], onDelete: Cascade)
  previousTenure BranchTenure? @relation("TenureRejoinChain", fields: [previousTenureId], references: [id], onDelete: SetNull)
  nextTenures    BranchTenure[] @relation("TenureRejoinChain")

  @@unique([branchMemberId, sequence])
  @@index([branchMemberId, joinedAt])
  @@map("branch_tenures")
}

// ╔══════════════════════════════════════════════════════════════════╗
// ║                     GROUPS (CLASSES / SECTIONS)                 ║
// ║  Represents a class + section within an academic year.          ║
// ║  Examples: "Playgroup", "Class 3-A", "Class 10-Bio"            ║
// ╚══════════════════════════════════════════════════════════════════╝

model Group {
  id               String   @id @default(uuid())
  academicYearId   String
  name             String // "Playgroup", "Class 3", "Class 10"
  section          String? // "A", "B" or "Bio", "CompSci", "Arts"
  displayOrder     Int // 1-13 for ordering/grade level
  capacity         Int      @default(30)
  onlyAdminCanSend Boolean  @default(true)
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  academicYear       AcademicYear        @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  members            GroupMember[]
  messages           Message[]
  students           Student[]
  groupSubjects      GroupSubject[]
  teacherAssignments TeacherAssignment[]
  enrollments        Enrollment[]
  timetableEntries   TimetableEntry[]
  examClasses        ExamClass[]
  announcements      Announcement[]

  createdById   String?
  updatedById   String?
  feeStructures FeeStructure[]
  studentFees   StudentFee[]

  @@unique([academicYearId, name, section])
  @@map("groups")
}

// Group membership (users in a group)
model GroupMember {
  id       String   @id @default(uuid())
  groupId  String
  userId   String
  role     Role
  joinedAt DateTime @default(now())

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdById String?
  updatedById String?

  @@unique([groupId, userId])
  @@map("group_members")
}

// ╔══════════════════════════════════════════════════════════════════╗
// ║                      SUBJECT                                    ║
// ║  Subjects exist at the AcademicYear level and are linked to     ║
// ║  specific groups via GroupSubject. One definition can be shared ║
// ║  across multiple groups/sections.                               ║
// ╚══════════════════════════════════════════════════════════════════╝

model Subject {
  id             String   @id @default(uuid())
  academicYearId String
  name           String // "English", "Mathematics", "Science"
  code           String? // Optional subject code (unique per AY)
  description    String?
  totalMarks     Float    @default(100)
  passingMarks   Float    @default(50)
  isElective     Boolean  @default(false)
  hodId          String? // Head of Department — FK to User
  createdAt      DateTime @default(now())

  academicYear       AcademicYear        @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  groupSubjects      GroupSubject[]
  teacherAssignments TeacherAssignment[]
  timetableEntries   TimetableEntry[]
  examClassSubjects  ExamClassSubject[]
  subjectResults     SubjectResult[]
  hod                User?               @relation("SubjectHOD", fields: [hodId], references: [id])

  updatedAt DateTime @updatedAt

  createdById String?
  updatedById String?

  @@unique([academicYearId, code])
  @@map("subjects")
}

// ╔══════════════════════════════════════════════════════════════════╗
// ║                    GROUP-SUBJECT LINKING                        ║
// ║  Links a subject to a specific group within an academic year.   ║
// ║  Enables sharing "English" across Class 1-A and Class 1-B.     ║
// ╚══════════════════════════════════════════════════════════════════╝

model GroupSubject {
  id        String @id @default(uuid())
  groupId   String
  subjectId String

  group   Group   @relation(fields: [groupId], references: [id], onDelete: Cascade)
  subject Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdById String?
  updatedById String?

  @@unique([groupId, subjectId])
  @@map("group_subjects")
}

// ╔══════════════════════════════════════════════════════════════════╗
// ║                     TEACHER PROFILE                             ║
// ║  Detailed profile for teacher role users.                       ║
// ╚══════════════════════════════════════════════════════════════════╝

enum TeacherPortalAccess {
  FULL
  READ_ONLY
  FROZEN
}

enum HodParentContactScope {
  ASSIGNED_ONLY
  DEPARTMENT_ALL
}

model TeacherProfile {
  id               String               @id @default(uuid())
  userId           String               @unique
  employeeId       String?              @unique
  portalAccess           TeacherPortalAccess   @default(FULL)
  portalPermissions      Json?
  canViewParentContact   Boolean               @default(false)
  hodParentContactScope  HodParentContactScope @default(ASSIGNED_ONLY)
  qualification    String?
  specialization   String?
  joiningDate      DateTime?
  salary           Decimal?  @db.Decimal(12, 2)
  phone            String?
  emergencyContact String?
  address          String?
  dateOfBirth      DateTime?
  gender           Gender?
  bloodGroup       String?
  fatherName       String?
  cardId           String?
  severeDisease    String?
  experience       String?
  bio              String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdById           String?
  updatedById           String?
  credentialGeneratedAt DateTime?
  credentialSentAt      DateTime?
  credentialDeliveredAt DateTime?
  credentialSeenAt      DateTime?
  passwordSetAt         DateTime?
  credentialStatus      String?   @default("none")

  @@map("teacher_profiles")
}

model StaffProfile {
  id               String    @id @default(uuid())
  userId           String    @unique
  employeeId       String?   @unique
  workRole         String?
  qualification    String?
  specialization   String?
  joiningDate      DateTime?
  salary           Decimal?  @db.Decimal(12, 2)
  phone            String?
  emergencyContact String?
  address          String?
  dateOfBirth      DateTime?
  gender           Gender?
  bloodGroup       String?
  fatherName       String?
  cardId           String?
  severeDisease    String?
  experience       String?
  bio              String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdById String?
  updatedById String?

  @@map("staff_profiles")
}

// ╔══════════════════════════════════════════════════════════════════╗
// ║                    TEACHER ASSIGNMENT                           ║
// ║  Assigns a teacher to teach a specific subject in a specific    ║
// ║  group during an academic year. isClassTeacher marks the homeroom ║
// ║  teacher for that group.                                        ║
// ╚══════════════════════════════════════════════════════════════════╝

model TeacherAssignment {
  id             String  @id @default(uuid())
  academicYearId String
  teacherId      String // FK → User (role=teacher)
  groupId        String
  subjectId      String
  isClassTeacher Boolean @default(false)
  role           String  @default("primary") // "primary", "assistant", "hod"
  validFrom      DateTime @default(now())
  validTo        DateTime?

  academicYear AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  teacher      User         @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  group        Group        @relation(fields: [groupId], references: [id], onDelete: Cascade)
  subject      Subject      @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdById String?
  updatedById String?

  @@map("teacher_assignments")
}

// ╔══════════════════════════════════════════════════════════════════╗
// ║                    MANAGEMENT PROFILE                           ║
// ║  Track admin/management staff details.                         ║
// ╚══════════════════════════════════════════════════════════════════╝

model ManagementProfile {
  id          String    @id @default(uuid())
  userId      String    @unique
  employeeId  String?   @unique
  department  String?
  designation String?
  permissions String[]  @default([])
  joiningDate DateTime?
  salary      Decimal?  @db.Decimal(12, 2)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdById String?
  updatedById String?

  @@map("management_profiles")
}

// ╔══════════════════════════════════════════════════════════════════╗
// ║                      PARENT PROFILE                             ║
// ╚══════════════════════════════════════════════════════════════════╝

model ParentProfile {
  id            String   @id @default(uuid())
  userId        String   @unique
  occupation    String?
  employerName  String?
  maritalStatus String?
  monthlyIncome String?
  relation      String? // "Father", "Mother", "Guardian"
  cnicNumber    String?  @unique
  phone         String?
  whatsapp      String?
  email         String?
  createdAt     DateTime @default(now())

  user     User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  children StudentParent[]

  updatedAt DateTime @updatedAt

  createdById String?
  updatedById String?

  @@map("parent_profiles")
}

// ╔══════════════════════════════════════════════════════════════════╗
// ║                     STUDENT PERSON                              ║
// ║  Stable identity across academic years (one row per human).     ║
// ╚══════════════════════════════════════════════════════════════════╝

model StudentPerson {
  id              String   @id @default(uuid())
  branchId        String
  userId          String?  @unique
  admissionNumber String?  @unique
  name            String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  branch        Branch                @relation(fields: [branchId], references: [id], onDelete: Cascade)
  user          User?                 @relation(fields: [userId], references: [id], onDelete: SetNull)
  yearRecords   Student[]
  schoolTenures StudentSchoolTenure[]

  @@index([branchId])
  @@map("student_persons")
}

// Append-only school join/leave/rejoin at branch level.
model StudentSchoolTenure {
  id               String           @id @default(uuid())
  personId         String
  branchId         String
  sequence         Int
  joinedAt         DateTime
  leftAt           DateTime?
  endReason        TenureEndReason?
  notes            String?
  previousTenureId String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  createdById      String?

  person         StudentPerson       @relation(fields: [personId], references: [id], onDelete: Cascade)
  previousTenure StudentSchoolTenure? @relation("StudentTenureRejoin", fields: [previousTenureId], references: [id], onDelete: SetNull)
  nextTenures    StudentSchoolTenure[] @relation("StudentTenureRejoin")

  @@unique([personId, sequence])
  @@index([branchId, joinedAt])
  @@map("student_school_tenures")
}

// ╔══════════════════════════════════════════════════════════════════╗
// ║                          STUDENT                                ║
// ║  Per-academic-year placement. personId links stable identity.    ║
// ╚══════════════════════════════════════════════════════════════════╝

model Student {
  id                      String                   @id @default(uuid())
  personId                String?
  academicYearId          String
  groupId                 String?
  familyId                String?
  name                    String
  rollNumber              String?
  admissionNumber         String?                  @unique
  dateOfBirth             DateTime?
  gender                  Gender?
  religion                String?
  nationality             String?                  @default("Pakistani")
  customFeeAmount         Int? // Per-student fee override (paise). Null = use class structure.
  concessionReason        String? // Reason: scholarship, discount, teachers child, etc.
  feeOverrides            Json? // Per-head overrides: {"headId": amount}
  address                 String?
  phone                   String?
  bloodGroup              String?
  bformCnic               String?
  motherTongue            String?
  studentEmail            String?
  studentWhatsapp         String?
  city                    String?
  postalCode              String?
  country                 String?
  previousSchool          String?
  previousClass           String?
  tcNumber                String?
  referredBy              String?
  profilePhotoId          String?                  @unique
  profileFile             FileRecord?              @relation("StudentProfilePhoto", fields: [profilePhotoId], references: [id])
  userId                  String?                  @unique
  user                    User?                    @relation(fields: [userId], references: [id], onDelete: SetNull)
  username                String?
  studentNumber           Int?                     @unique
  status                  StudentStatus            @default(ACTIVE)
  isActive                Boolean                  @default(true)
  admissionDate           DateTime                 @default(now())
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  createdById             String?
  updatedById             String?
  createdBy               User?                    @relation("StudentCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy               User?                    @relation("StudentUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  credentialGeneratedAt   DateTime?
  credentialSentAt        DateTime?
  credentialDeliveredAt   DateTime?
  credentialSeenAt        DateTime?
  passwordSetAt           DateTime?
  credentialStatus        String?                  @default("none")
  credentialTag           StudentCredentialTag     @default(CRED_NONE)
  credentialSends         CredentialSend[]
  statusLogs              StudentStatusLog[]
  attendanceNotifications AttendanceNotification[]
  classMovements          StudentClassMovement[]
  stationaryRecords       StudentStationaryRecord[]

  person            StudentPerson?     @relation(fields: [personId], references: [id], onDelete: SetNull)
  academicYear      AcademicYear       @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  group             Group?             @relation(fields: [groupId], references: [id], onDelete: SetNull)
  family            Family?            @relation("StudentFamily", fields: [familyId], references: [id], onDelete: SetNull)
  parents           StudentParent[]
  enrollments       Enrollment[]
  emergencyContacts EmergencyContact[]
  healthRecord      HealthRecord?
  attendances       Attendance[]
  studentFees       StudentFee[]
  feePayments       Payment[]          @relation("PaymentStudent")
  examMarks         MarksEntry[]
  subjectResults    SubjectResult[]
  reportCards       ReportCard[]
  canteenAccounts   CanteenAccount[]
  feeCarryForwardsFrom FeeCarryForward[] @relation("FeeCarryFrom")
  feeCarryForwardsTo   FeeCarryForward[] @relation("FeeCarryTo")

  @@index([groupId])
  @@index([familyId])
  @@index([academicYearId])
  @@index([personId])
  @@map("students")
}

// Unlimited mid-year class changes within an academic year (append-only).
model StudentClassMovement {
  id             String   @id @default(uuid())
  studentId      String
  academicYearId String
  sequence       Int
  fromGroupId    String?
  toGroupId      String
  effectiveAt    DateTime
  reason         String?
  createdById    String?
  createdAt      DateTime @default(now())

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, sequence])
  @@index([academicYearId, effectiveAt])
  @@map("student_class_movements")
}

// ─── Attendance (one row per student per day per AY) ─────────
model Attendance {
  id             String   @id @default(uuid())
  studentId      String
  academicYearId String
  date           DateTime @db.Date
  status         String // "present" | "absent" | "late" | "leave" | "holiday" | "function"
  note           String?
  markedById     String?

  student      Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  academicYear AcademicYear @relation(fields: [academicYearId], references: [id])
  markedBy     User?        @relation(fields: [markedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([studentId, date])
  @@index([academicYearId, date])
  @@map("attendances")
}

model TeacherAttendance {
  id             String   @id @default(uuid())
  teacherId      String
  academicYearId String
  date           DateTime @db.Date
  status         String // "present" | "absent" | "late" | "leave" | "holiday" | "function"
  note           String?
  markedById     String?

  teacher      User         @relation("TeacherAttendanceTeacher", fields: [teacherId], references: [id], onDelete: Cascade)
  academicYear AcademicYear @relation(fields: [academicYearId], references: [id])
  markedBy     User?        @relation("TeacherAttendanceMarkedBy", fields: [markedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([teacherId, date])
  @@index([academicYearId, date])
  @@map("teacher_attendances")
}

model StaffAttendance {
  id             String   @id @default(uuid())
  staffUserId    String
  academicYearId String
  date           DateTime @db.Date
  status         String // present | absent | late | leave | holiday | function
  note           String?
  markedById     String?

  staff        User         @relation("StaffAttendanceStaff", fields: [staffUserId], references: [id], onDelete: Cascade)
  academicYear AcademicYear @relation(fields: [academicYearId], references: [id])
  markedBy     User?        @relation("StaffAttendanceMarkedBy", fields: [markedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([staffUserId, date])
  @@index([academicYearId, date])
  @@map("staff_attendances")
}

// Credential send history (redacted — no passwords stored)
model CredentialSend {
  id          String    @id @default(uuid())
  studentId   String
  sentAt      DateTime  @default(now())
  deliveredAt DateTime?
  seenAt      DateTime?
  status      String // "sent" | "delivered" | "read" | "failed"
  to          String? // Masked phone: "03XX-XXXXXX"
  errorMsg    String?
  sentById    String?

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  sentBy  User?   @relation(fields: [sentById], references: [id])

  @@index([studentId])
  @@map("credential_sends")
}

// Student-Parent linking (many-to-many)
model StudentParent {
  id        String   @id @default(uuid())
  studentId String
  parentId  String
  relation  String // "Father", "Mother", "Guardian"
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())

  student Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  parent  ParentProfile @relation(fields: [parentId], references: [id], onDelete: Cascade)

  updatedAt DateTime @updatedAt

  createdById String?
  updatedById String?

  @@unique([studentId, parentId])
  @@map("student_parents")
}

// ╔══════════════════════════════════════════════════════════════════╗
// ║                    EMERGENCY CONTACT                             ║
// ╚══════════════════════════════════════════════════════════════════╝

model EmergencyContact {
  id           String   @id @default(uuid())
  studentId    String
  name         String
  relationship String
  phone        String
  whatsapp     String?
  priority     Int      @default(1)
  createdAt    DateTime @default(now())

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  updatedAt DateTime @updatedAt

  createdById String?
  updatedById String?

  @@map("emergency_contacts")
}

// ╔══════════════════════════════════════════════════════════════════╗
// ║                      HEALTH RECORD                              ║
// ║  One record per student.                                        ║
// ╚══════════════════════════════════════════════════════════════════╝

model HealthRecord {
  id                String   @id @default(uuid())
  studentId         String   @unique
  bloodGroup        String?
  hasChronicDisease Boolean  @default(false)
  diseaseDetails    String?
  allergies         String?
  disability        String?
  medicalNotes      String?
  doctorName        String?
  doctorPhone       String?
  updatedAt         DateTime @updatedAt

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  createdById String?
  updatedById String?

  @@map("health_records")
}

// ╔══════════════════════════════════════════════════════════════════╗
// ║                       ENROLLMENT                                ║
// ║  One record per student per academic year. Immutable after      ║
// ║  creation (only leftAt can be set at year-end close).           ║
// ╚══════════════════════════════════════════════════════════════════╝

model Enrollment {
  id             String    @id @default(uuid())
  studentId      String
  academicYearId String
  groupId        String
  rollNumber     String?
  joinedAt       DateTime  @default(now())
  leftAt         DateTime?

  student      Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  academicYear AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  group        Group        @relation(fields: [groupId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdById String?
  updatedById String?

  @@unique([studentId, academicYearId])
  @@map("enrollments")
}

// ╔══════════════════════════════════════════════════════════════════╗
// ║                    ACADEMIC YEAR SNAPSHOT                       ║
// ║  Records a year-end close / batch promotion event. Contains     ║
// ║  frozen snapshot of all groups within the academic year.        ║
// ╚══════════════════════════════════════════════════════════════════╝

model AcademicYearSnapshot {
  id                String          @id @default(uuid())
  academicYearId    String
  newAcademicYearId String?
  fromLabel         String // Human label of source year
  toLabel           String // Human label of target year
  triggeredById     String // User who triggered the close
  status            PromotionStatus @default(PENDING)
  totalStudents     Int             @default(0)
  totalGraduated    Int             @default(0)
  canReverse        Boolean         @default(true)
  reversedAt        DateTime?
  createdAt         DateTime        @default(now())

  academicYear    AcademicYear    @relation("SourceAcademicYear", fields: [academicYearId], references: [id], onDelete: Cascade)
  newAcademicYear AcademicYear?   @relation("NewAcademicYear", fields: [newAcademicYearId], references: [id])
  triggeredBy     User            @relation("SnapshotTriggeredBy", fields: [triggeredById], references: [id])
  groupSnapshots  GroupSnapshot[]
  promotionRuns   BatchPromotionRun[]

  updatedAt DateTime @updatedAt

  createdById String?
  updatedById String?

  @@map("academic_year_snapshots")
}

// ╔══════════════════════════════════════════════════════════════════╗
// ║                      GROUP SNAPSHOT                             ║
// ║  Frozen state of a group at year-end close time.                ║
// ║  studentsData and teachersData are JSON snapshots.              ║
// ╚══════════════════════════════════════════════════════════════════╝

model GroupSnapshot {
  id           String  @id @default(uuid())
  snapshotId   String
  groupId      String // Original group ID (not FK — group may change)
  groupName    String
  section      String?
  displayOrder Int
  studentsData Json? // Frozen student list
  teachersData Json? // Frozen teacher assignments
  studentCount Int     @default(0)

  snapshot AcademicYearSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdById String?
  updatedById String?

  @@map("group_snapshots")
}

// ╔══════════════════════════════════════════════════════════════════╗
// ║                    ANNOUNCEMENTS                                ║
// ╚══════════════════════════════════════════════════════════════════╝

model Announcement {
  id             String   @id @default(uuid())
  academicYearId String
  groupId        String? // null = school-wide; set = class-targeted (teachers assigned to group only)
  senderId       String
  title          String
  content        String?
  mediaUrl       String?
  isPinned       Boolean  @default(false)
  createdAt      DateTime @default(now())

  academicYear AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  group        Group?       @relation(fields: [groupId], references: [id], onDelete: Cascade)

  updatedAt DateTime @updatedAt

  @@index([academicYearId, groupId, createdAt])
  @@map("announcements")
}

// ╔══════════════════════════════════════════════════════════════════╗
// ║                     MESSAGES (GROUP CHAT)                       ║
// ╚══════════════════════════════════════════════════════════════════╝

model Message {
  id        String   @id @default(uuid())
  groupId   String
  senderId  String
  content   String?
  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  group  Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  sender User  @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([groupId, createdAt])
  @@map("messages")
}

// Attendance notifications for parents (queued for chat app pickup)
model AttendanceNotification {
  id        String    @id @default(uuid())
  studentId String
  date      DateTime  @db.Date
  status    String
  message   String
  sent      Boolean   @default(false)
  sentAt    DateTime?
  createdAt DateTime  @default(now())

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([sent])
  @@map("attendance_notifications")
}

// ╔══════════════════════════════════════════════════════════════════╗
// ║                    BATCH PROMOTION                              ║
// ╚══════════════════════════════════════════════════════════════════╝

model BatchPromotion {
  id             String    @id @default(uuid())
  academicYearId String
  fromYear       String
  toYear         String
  promotedById   String
  status         String    @default("pending")
  totalStudents  Int
  canReverse     Boolean   @default(true)
  reversedAt     DateTime?
  notes          String?
  createdAt      DateTime  @default(now())

  promotedBy User @relation("PromotedByUser", fields: [promotedById], references: [id])

  updatedAt DateTime @updatedAt

  createdById String?
  updatedById String?

  @@map("batch_promotions")
}

model BatchPromotionRun {
  id                   String                 @id @default(uuid())
  branchId             String
  sourceAcademicYearId String
  targetAcademicYearId String
  phase                BatchPromotionRunPhase @default(DRAFT)
  carryOptions         Json
  snapshotId           String?
  promotedById         String
  notes                String?
  errorMessage         String?
  publishedAt          DateTime?
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt

  branch       Branch               @relation(fields: [branchId], references: [id], onDelete: Cascade)
  sourceAy     AcademicYear         @relation("PromotionSourceAy", fields: [sourceAcademicYearId], references: [id], onDelete: Cascade)
  targetAy     AcademicYear         @relation("PromotionTargetAy", fields: [targetAcademicYearId], references: [id], onDelete: Cascade)
  snapshot     AcademicYearSnapshot? @relation(fields: [snapshotId], references: [id], onDelete: SetNull)
  promotedBy   User                 @relation("BatchPromotionTriggeredBy", fields: [promotedById], references: [id])

  @@index([branchId, phase])
  @@index([sourceAcademicYearId])
  @@index([targetAcademicYearId])
  @@map("batch_promotion_runs")
}

model TeacherAySnapshot {
  id             String   @id @default(uuid())
  academicYearId String
  teacherId      String
  assignments    Json
  firstAssignedAt DateTime?
  lastAssignedAt  DateTime?
  createdAt      DateTime @default(now())

  academicYear AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)

  @@unique([academicYearId, teacherId])
  @@map("teacher_ay_snapshots")
}

// ╔══════════════════════════════════════════════════════════════════╗
// ║                    NOTIFICATION SYSTEM                          ║
// ╚══════════════════════════════════════════════════════════════════╝

model NotificationRecipient {
  id        String    @id @default(uuid())
  userId    String
  title     String
  body      String
  type      String // "announcement", "message", etc.
  data      Json?
  isRead    Boolean   @default(false)
  readAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  updatedAt DateTime @updatedAt

  @@index([userId, isRead])
  @@map("notification_recipients")
}

// Device tokens for push notifications
model DeviceToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  platform  String // "android", "ios", "web"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("device_tokens")
}

// ╔══════════════════════════════════════════════════════════════════╗
// ║                    PASSWORD RESET TOKENS                        ║
// ╚══════════════════════════════════════════════════════════════════╝

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id])

  updatedAt DateTime @updatedAt

  @@index([token])
  @@map("password_reset_tokens")
}

// ╔══════════════════════════════════════════════════════════════════╗
// ║                    EXAM & GRADES MODULE                         ║
// ╚══════════════════════════════════════════════════════════════════╝

model ExamType {
  id            String   @id @default(uuid())
  name          String
  defaultWeight Float?
  examSessionId String
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  createdById String?
  updatedById String?

  examSession ExamSession @relation(fields: [examSessionId], references: [id], onDelete: Cascade)
  exams       Exam[]

  @@unique([examSessionId, name])
  @@index([examSessionId])
  @@map("exam_types")
}

model ExamSession {
  id             String   @id @default(uuid())
  name           String
  academicYearId String
  startDate      DateTime
  endDate        DateTime
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  createdById String?
  updatedById String?

  academicYear   AcademicYear    @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  examTypes      ExamType[]
  exams          Exam[]
  subjectResults SubjectResult[]
  reportCards    ReportCard[]

  @@index([academicYearId])
  @@map("exam_sessions")
}

model Exam {
  id             String     @id @default(uuid())
  examSessionId  String
  examTypeId     String
  name           String
  weightOverride Float?
  startDate      DateTime
  endDate        DateTime?
  status            ExamStatus @default(DRAFT)
  teacherMarksEntry Boolean    @default(true)
  createdAt         DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  createdById String?
  updatedById String?

  examSession ExamSession @relation(fields: [examSessionId], references: [id], onDelete: Cascade)
  examType    ExamType    @relation(fields: [examTypeId], references: [id])
  examClasses ExamClass[]

  @@index([examSessionId])
  @@index([examTypeId])
  @@map("exams")
}

model ExamClass {
  id        String   @id @default(uuid())
  examId    String
  classId   String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdById String?
  updatedById String?

  exam     Exam               @relation(fields: [examId], references: [id], onDelete: Cascade)
  class    Group              @relation(fields: [classId], references: [id])
  subjects ExamClassSubject[]

  @@unique([examId, classId])
  @@index([classId])
  @@map("exam_classes")
}

model ExamClassSubject {
  id           String   @id @default(uuid())
  examClassId  String
  subjectId    String
  isActive     Boolean  @default(true)
  totalMarks   Int?
  passingMarks Int?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  createdById String?
  updatedById String?

  examClass    ExamClass    @relation(fields: [examClassId], references: [id], onDelete: Cascade)
  subject      Subject      @relation(fields: [subjectId], references: [id])
  marksEntries MarksEntry[]

  @@unique([examClassId, subjectId])
  @@index([subjectId])
  @@map("exam_class_subjects")
}

model MarksEntry {
  id                 String   @id @default(uuid())
  examClassSubjectId String
  studentId          String
  marksObtained      Float?
  isAbsent           Boolean  @default(false)
  enteredBy          String
  enteredAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  createdById String?
  updatedById String?

  examClassSubject ExamClassSubject @relation(fields: [examClassSubjectId], references: [id], onDelete: Cascade)
  student          Student          @relation(fields: [studentId], references: [id])
  enteredByUser    User             @relation("MarksEnteredBy", fields: [enteredBy], references: [id], onDelete: SetNull)

  @@unique([examClassSubjectId, studentId])
  @@index([studentId])
  @@index([enteredBy])
  @@map("marks_entries")
}

model GradeScale {
  id        String   @id @default(uuid())
  name      String
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdById String?
  updatedById String?

  bands GradeBand[]

  @@map("grade_scales")
}

model GradeBand {
  id           String   @id @default(uuid())
  gradeScaleId String
  minPercent   Float
  maxPercent   Float
  label        String
  gpa          Float?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  createdById String?
  updatedById String?

  gradeScale GradeScale @relation(fields: [gradeScaleId], references: [id], onDelete: Cascade)

  @@index([gradeScaleId])
  @@map("grade_bands")
}

model SubjectResult {
  id            String   @id @default(uuid())
  studentId     String
  examSessionId String
  subjectId     String
  percentage    Float
  grade         String
  subjectRank   Int?
  computedAt    DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  createdById String?
  updatedById String?

  student     Student     @relation(fields: [studentId], references: [id])
  examSession ExamSession @relation(fields: [examSessionId], references: [id], onDelete: Cascade)
  subject     Subject     @relation(fields: [subjectId], references: [id])

  @@unique([studentId, examSessionId, subjectId])
  @@index([examSessionId])
  @@index([subjectId])
  @@map("subject_results")
}

model ReportCard {
  id                String           @id @default(uuid())
  studentId         String
  examSessionId     String
  overallPercentage Float
  overallGrade      String
  classRank         Int?
  pdfUrl            String?
  status            ReportCardStatus @default(DRAFT)
  generatedAt       DateTime         @default(now())
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  createdById String?
  updatedById String?

  student     Student     @relation(fields: [studentId], references: [id])
  examSession ExamSession @relation(fields: [examSessionId], references: [id], onDelete: Cascade)

  @@unique([studentId, examSessionId])
  @@index([examSessionId])
  @@map("report_cards")
}

// ╔══════════════════════════════════════════════════════════════════╗
// ║                       AUDIT TRAIL                               ║
// ╚══════════════════════════════════════════════════════════════════╝

model AuditLog {
  id        String   @id @default(uuid())
  userId    String? // nullable — system events and deleted-user scenarios must never break the audit trail
  action    String
  entity    String
  entityId  String?
  oldValue  Json?
  newValue  Json?
  metadata  Json?
  ipAddress String?
  userAgent String?
  module    String   @default("system")
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  updatedAt DateTime @updatedAt

  @@index([userId, createdAt])
  @@index([entity, entityId])
  @@index([module, entity, entityId])
  @@map("audit_logs")
}

// ╔══════════════════════════════════════════════════════════════════╗
// ║                         API KEYS                                ║
// ╚══════════════════════════════════════════════════════════════════╝

model ApiKey {
  id         String     @id @default(uuid())
  name       String
  type       ApiKeyType @default(publishable)
  keyHash    String     @unique
  prefix     String // e.g. "mcs_abc1"
  createdBy  String
  lastUsedAt DateTime?
  expiresAt  DateTime?
  revokedAt  DateTime?
  createdAt  DateTime   @default(now())

  updatedAt DateTime @updatedAt

  @@index([prefix])
  @@index([revokedAt])
  @@index([type])
  @@map("api_keys")
}

// ╔══════════════════════════════════════════════════════════════════╗
// ║                     ADMIN INVITATIONS                           ║
// ╚══════════════════════════════════════════════════════════════════╝

model AdminInvitation {
  id        String    @id @default(uuid())
  email     String
  name      String?
  phone     String?
  branchId  String
  token     String    @unique
  usedAt    DateTime?
  expiresAt DateTime
  createdAt DateTime  @default(now())

  branch Branch @relation(fields: [branchId], references: [id])

  updatedAt DateTime @updatedAt

  createdById String?
  updatedById String?

  @@index([token])
  @@index([email])
  @@index([branchId])
  @@map("admin_invitations")
}

// ╔══════════════════════════════════════════════════════════════════╗
// ║                   TIMETABLE SLOTS                               ║
// ║  Universal time grid for all classes within an academic year.  ║
// ║  Defines the lecture periods (start-end time) for each day.    ║
// ╚══════════════════════════════════════════════════════════════════╝

// ╔══════════════════════════════════════════════════════════════════╗
// ║              TIMETABLE (parent entity)                          ║
// ║  Each timetable/datesheet has its own ID, name, type.          ║
// ║  Slots, day configs, and entries all reference this ID.        ║
// ╚══════════════════════════════════════════════════════════════════╝

model Timetable {
  id             String   @id @default(uuid())
  academicYearId String
  name           String // Display name (regular, friday-schedule, exam-week)
  type           String   @default("timetable") // "timetable" or "datesheet"
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())

  academicYear AcademicYear         @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  slots        TimetableSlot[]
  dayConfigs   TimetableDayConfig[]

  updatedAt DateTime @updatedAt

  createdById String?
  updatedById String?

  @@unique([academicYearId, name])
  @@map("timetables")
}

model TimetableSlot {
  id            String   @id @default(uuid())
  timetableId   String
  dayOfWeek     Int? // null = all days, 1=Monday ... 6=Saturday
  lectureNumber Int // 1, 2, 3...
  startTime     String // "08:00"
  endTime       String // "08:40"
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())

  timetable Timetable        @relation(fields: [timetableId], references: [id], onDelete: Cascade)
  entries   TimetableEntry[]

  updatedAt DateTime @updatedAt

  createdById String?
  updatedById String?

  @@unique([timetableId, lectureNumber])
  @@map("timetable_slots")
}

// ╔══════════════════════════════════════════════════════════════════╗
// ║                   TIMETABLE ENTRIES                             ║
// ║  Links a slot → section → subject + teacher.                   ║
// ║  One entry per slot per section.                               ║
// ╚══════════════════════════════════════════════════════════════════╝

model TimetableEntry {
  id        String  @id @default(uuid())
  slotId    String
  groupId   String // FK → Group (section)
  subjectId String?
  teacherId String?
  note      String? // "break", etc.

  slot    TimetableSlot @relation(fields: [slotId], references: [id], onDelete: Cascade)
  group   Group         @relation(fields: [groupId], references: [id], onDelete: Cascade)
  subject Subject?      @relation(fields: [subjectId], references: [id])
  teacher User?         @relation("TimetableTeacher", fields: [teacherId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdById String?
  updatedById String?

  @@unique([slotId, groupId])
  @@map("timetable_entries")
}

// ╔══════════════════════════════════════════════════════════════════╗
// ║              TIMETABLE DAY CONFIG                               ║
// ║  Stores which days are active per timetable.                   ║
// ╚══════════════════════════════════════════════════════════════════╝

model TimetableDayConfig {
  id          String   @id @default(uuid())
  timetableId String
  dayOfWeek   Int // 1=Mon ... 6=Sat
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  timetable Timetable @relation(fields: [timetableId], references: [id], onDelete: Cascade)

  updatedAt DateTime @updatedAt

  createdById String?
  updatedById String?

  @@unique([timetableId, dayOfWeek])
  @@map("timetable_day_configs")
}

// ╔══════════════════════════════════════════════════════════════════╗
// ║                    STUDENT STATUS LOG                            ║
// ║  Tracks every status change with reason and who changed it.     ║
// ╚══════════════════════════════════════════════════════════════════╝

model StudentStatusLog {
  id             String         @id @default(uuid())
  studentId      String
  previousStatus StudentStatus?
  newStatus      StudentStatus
  reason         String?
  changedById    String?
  createdAt      DateTime       @default(now())

  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  changedBy User?   @relation(fields: [changedById], references: [id])

  @@index([studentId])
  @@map("student_status_logs")
}

// ╔══════════════════════════════════════════════════════════════════╗
// ║                     FEE / PAYMENT SYSTEM                        ║
// ║  Family grouping, fee heads, structures, student fees,          ║
// ║  payments, receipts, and sibling combined payments.             ║
// ╚══════════════════════════════════════════════════════════════════╝

model Family {
  id         String   @id @default(uuid())
  name       String
  fatherName String?
  motherName String?
  phone      String?
  address    String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  createdById String?
  updatedById String?

  students   Student[]         @relation("StudentFamily")
  payments   FamilyPayment[]
  changeLogs FamilyChangeLog[]
  createdBy  User?             @relation("FamilyCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy  User?             @relation("FamilyUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  @@index([name])
  @@index([isActive])
  @@index([createdById])
  @@map("families")
}

// Tracks family membership and profile changes (student add/remove, deactivation, etc.)
model FamilyChangeLog {
  id          String   @id @default(uuid())
  familyId    String
  action      String   // CREATED | UPDATED | STUDENT_ADDED | STUDENT_REMOVED | DEACTIVATED | REACTIVATED
  details     Json?
  changedById String?
  createdAt   DateTime @default(now())

  family    Family @relation(fields: [familyId], references: [id], onDelete: Cascade)
  changedBy User?  @relation(fields: [changedById], references: [id], onDelete: SetNull)

  @@index([familyId])
  @@index([changedById])
  @@map("family_change_logs")
}

model FeeHead {
  id          String   @id @default(uuid())
  name        String // Tuition, Transport, Lab, Library, etc.
  description String?
  isOptional  Boolean  @default(false)
  isActive    Boolean  @default(true)
  category    String   @default("MONTHLY") // MONTHLY | TERM | ANNUAL | ONE_TIME
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  structures      FeeStructure[]
  headAllocations PaymentHeadAllocation[]

  @@map("fee_heads")
}

model FeeStructure {
  id             String    @id @default(uuid())
  academicYearId String
  groupId        String
  feeHeadId      String
  amount         Int // In paise (500000 = 5000 PKR)
  effectiveFrom  DateTime  @default(now())
  effectiveTo    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  academicYear AcademicYear   @relation(fields: [academicYearId], references: [id])
  group        Group          @relation(fields: [groupId], references: [id])
  feeHead      FeeHead        @relation(fields: [feeHeadId], references: [id])
  changeLogs   FeeChangeLog[]

  @@unique([academicYearId, groupId, feeHeadId, effectiveFrom])
  @@index([academicYearId, groupId])
  @@map("fee_structures")
}

model FeeChangeLog {
  id             String   @id @default(uuid())
  feeStructureId String
  previousAmount Int
  newAmount      Int
  reason         String?
  changedById    String
  changedAt      DateTime @default(now())

  feeStructure FeeStructure @relation(fields: [feeStructureId], references: [id])
  changedBy    User         @relation(fields: [changedById], references: [id])

  @@index([feeStructureId])
  @@map("fee_change_logs")
}

model StudentFee {
  id               String    @id @default(uuid())
  academicYearId   String
  studentId        String
  groupId          String? // Snapshot of class at generation time
  month            Int // 1-12
  year             Int
  totalAmount      Int // Sum of all applicable heads (paise)
  concession       Int       @default(0)
  lateFee          Int       @default(0)
  netAmount        Int // totalAmount - concession + lateFee
  extraCharges     Int       @default(0) // Additional charges on top of base fee
  extraReason      String? // Reason for extra charges
  paidAmount       Int       @default(0)
  feeHeadBreakdown Json? // Array of {name, amount, category} from generation
  status           String    @default("UNPAID") // UNPAID | PARTIAL | PAID | OVERPAID | WAIVED
  dueDate          DateTime?
  paidAt           DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  academicYear    AcademicYear            @relation(fields: [academicYearId], references: [id])
  student         Student                 @relation(fields: [studentId], references: [id])
  group           Group?                  @relation(fields: [groupId], references: [id])
  payments        Payment[]
  extraItems      FeeExtraItem[]
  headAllocations PaymentHeadAllocation[]
  carryForwardsFrom FeeCarryForward[] @relation("FeeCarryFromFee")
  carryForwardsTo   FeeCarryForward[] @relation("FeeCarryToFee")
  stationaryRecords StudentStationaryRecord[]

  @@unique([studentId, month, year, academicYearId])
  @@index([month, year, status])
  @@index([academicYearId, status])
  @@map("student_fees")
}

model FeeExtraItem {
  id           String   @id @default(uuid())
  studentFeeId String
  name         String
  amount       Int // in paise
  sourceType   String?  @default("EXTRA_DUE") // EXTRA_DUE | STATIONARY
  metadata     Json?
  stationaryRecordItemId String?
  createdAt    DateTime @default(now())

  studentFee      StudentFee              @relation(fields: [studentFeeId], references: [id], onDelete: Cascade)
  headAllocations PaymentHeadAllocation[]
  stationaryRecordItem StudentStationaryRecordItem? @relation(fields: [stationaryRecordItemId], references: [id], onDelete: SetNull)

  @@index([studentFeeId])
  @@index([sourceType])
  @@index([stationaryRecordItemId])
  @@map("fee_extra_items")
}

// Manual link when outstanding balance is moved from an archived AY fee to a new AY fee.
model FeeCarryForward {
  id               String   @id @default(uuid())
  fromStudentFeeId String
  toStudentFeeId   String
  fromStudentId    String?
  toStudentId      String?
  amount           Int
  notes            String?
  createdById      String?
  createdAt        DateTime @default(now())

  fromStudentFee StudentFee @relation("FeeCarryFromFee", fields: [fromStudentFeeId], references: [id], onDelete: Cascade)
  toStudentFee   StudentFee @relation("FeeCarryToFee", fields: [toStudentFeeId], references: [id], onDelete: Cascade)
  fromStudent    Student?   @relation("FeeCarryFrom", fields: [fromStudentId], references: [id], onDelete: SetNull)
  toStudent      Student?   @relation("FeeCarryTo", fields: [toStudentId], references: [id], onDelete: SetNull)

  @@index([fromStudentFeeId])
  @@index([toStudentFeeId])
  @@map("fee_carry_forwards")
}

model FamilyPayment {
  id            String   @id @default(uuid())
  familyId      String
  academicYearId String?
  receiptNumber String   @unique // FMP-YYYYMM-XXXX
  totalAmount   Int
  paymentMethod String?
  reference     String?
  note          String?
  paymentDate   DateTime @default(now())
  recordedById  String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  family     Family    @relation(fields: [familyId], references: [id])
  payments   Payment[]
  receipt    FamilyPaymentReceipt?
  recordedBy User      @relation(fields: [recordedById], references: [id])

  @@index([familyId])
  @@index([academicYearId])
  @@map("family_payments")
}

// Combined family receipt snapshot — one per FamilyPayment (FMP-…)
model FamilyPaymentReceipt {
  id                String   @id @default(uuid())
  familyPaymentId   String   @unique
  receiptNumber     String
  templateType      String   // FIRST | ARREARS | CONTINUATION
  snapshot          Json     // Full receipt payload for print/reprint
  totalDuePaise     Int
  amountPaidPaise   Int
  balanceAfterPaise Int
  paymentMethod     String?
  reference         String?
  paymentDate       DateTime
  printedAt         DateTime?
  printCount        Int      @default(0)
  createdAt         DateTime @default(now())

  familyPayment FamilyPayment @relation(fields: [familyPaymentId], references: [id], onDelete: Cascade)

  @@index([receiptNumber])
  @@map("family_payment_receipts")
}

model Payment {
  id              String    @id @default(uuid())
  studentFeeId    String
  studentId       String
  familyPaymentId String?
  amount          Int // In paise
  paymentMethod   String // CASH | CHEQUE | BANK_TRANSFER
  receiptNumber   String    @unique // RCP-YYYYMM-XXXX
  reference       String? // Cheque number / transaction ID
  paymentDate     DateTime  @default(now())
  recordedById    String
  note            String?
  revertedAt      DateTime?
  revertedById    String?
  revertReason    String?
  createdAt       DateTime  @default(now())

  studentFee      StudentFee              @relation(fields: [studentFeeId], references: [id])
  student         Student                 @relation("PaymentStudent", fields: [studentId], references: [id], onDelete: Cascade)
  familyPayment   FamilyPayment?          @relation(fields: [familyPaymentId], references: [id])
  receipt         PaymentReceipt? // One immutable receipt per payment
  auditLogs       PaymentAuditLog[]
  headAllocations PaymentHeadAllocation[]

  recordedBy User  @relation("PaymentRecordedBy", fields: [recordedById], references: [id])
  revertedBy User? @relation("PaymentRevertedBy", fields: [revertedById], references: [id])

  @@index([studentFeeId])
  @@index([familyPaymentId])
  @@index([receiptNumber])
  @@index([studentId])
  @@map("payments")
}

// ─── Payment Head Allocation ────────────────────────────────────────
// Head/extra-level split of a single Payment, for the manual allocation
// flow (Step 1 UI: accountant selects specific fee heads and extras
// within the current month, plus whole previous months). Only current-
// month payments get rows here — previous months stay whole, never split
// by head, matching the UI (previous months have no sub-cat checkboxes).
// Exactly one of feeHeadId / feeExtraItemId is set per row, never both,
// never neither.
model PaymentHeadAllocation {
  id             String    @id @default(uuid())
  paymentId      String
  studentFeeId   String
  feeHeadId      String?
  feeExtraItemId String?
  amount         Int // in paise
  revertedAt     DateTime?
  createdAt      DateTime  @default(now())

  payment      Payment       @relation(fields: [paymentId], references: [id])
  studentFee   StudentFee    @relation(fields: [studentFeeId], references: [id])
  feeHead      FeeHead?      @relation(fields: [feeHeadId], references: [id])
  feeExtraItem FeeExtraItem? @relation(fields: [feeExtraItemId], references: [id])

  @@index([paymentId])
  @@index([studentFeeId])
  @@index([feeHeadId])
  @@index([feeExtraItemId])
  @@map("payment_head_allocations")
}

// ─── Receipt Snapshot ───────────────────────────────────────────────
// Stores exactly what was shown on the receipt at payment time.
// One snapshot per Payment. Immutable after creation.
model PaymentReceipt {
  id            String @id @default(uuid())
  paymentId     String @unique
  receiptNumber String // Denormalized for fast lookup

  // Current month (the one being paid) — full breakdown
  currentMonthLabel  String // "Jun 2026"
  currentMonthTotal  Int // in paise
  currentMonthHeads  Json // [{name:"Tuition", amount:300000}, ...]
  currentMonthExtras Json? // [{name:"Lab", amount:50000}, ...]

  // Previous months — one combined line
  previousBalancePaise Int // sum of what was due from earlier months
  previousMonthsCount  Int // how many months in the previous balance
  // Per-month arrears detail — [{label, dueBeforePaise, paidPaise, remainingPaise}, ...]
  previousMonths Json?

  // FIRST | ARREARS | CONTINUATION — mirrors family receipt templates
  templateType String?

  // Per-month allocation breakdown for waterfall/family payments that span
  // multiple months in one transaction — [{label:"Jun 2026", amountPaise:50000}, ...]
  // Null/empty for single-fee payments (currentMonth section covers it alone).
  allocations Json?

  // Summary
  totalDuePaise     Int // currentMonthTotal + previousBalancePaise
  amountPaidPaise   Int // what this payment covered
  balanceAfterPaise Int // remaining after this payment

  // Context at time of payment
  paymentMethod String
  reference     String?
  studentName   String
  studentClass  String
  studentRoll   String?
  fatherName    String?
  isFullyPaid   Boolean

  // Audit
  paymentDate DateTime
  printedAt   DateTime? // first print timestamp
  printCount  Int       @default(0)
  createdAt   DateTime  @default(now())

  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([paymentId])
  @@index([receiptNumber])
  @@map("payment_receipts")
}

// ─── Payment Audit Trail ──────────────────────────────────────────
// Every action on a payment: create, revert, modify, print.
model PaymentAuditLog {
  id              String   @id @default(uuid())
  paymentId       String
  action          String // CREATED | REVERTED | REPRINTED | DOWNLOADED | MODIFIED
  previousValue   Json? // Payment state before change
  newValue        Json? // Payment state after change
  performedById   String
  performedByName String? // Denormalized for audit readability
  ipAddress       String?
  userAgent       String?
  createdAt       DateTime @default(now())

  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([paymentId, createdAt])
  @@index([performedById, createdAt])
  @@map("payment_audit_logs")
}

// ╔══════════════════════════════════════════════════════════════════╗
// ║                    CANTEEN MANAGEMENT                           ║
// ║  Branch-scoped ONLY — no academicYearId on any canteen table.   ║
// ║  Not tied to fee/payment. Admin full control; canteen_staff    ║
// ║  (BranchRole) = daily sales only.                               ║
// ║  Credit (bakaya): branch students / teachers / staff ONLY —      ║
// ║  must link Student or User; no ad-hoc name+phone accounts.      ║
// ╚══════════════════════════════════════════════════════════════════╝

model CanteenSupplier {
  id                    String   @id @default(uuid())
  branchId              String
  name                  String
  contactNumber         String?
  note                  String?
  balanceOwedToSupplier Decimal  @default(0) @db.Decimal(12, 2) // we owe them
  balanceSupplierOwesUs Decimal  @default(0) @db.Decimal(12, 2) // they owe us
  isActive              Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  createdById           String?
  updatedById           String?

  branch           Branch                    @relation(fields: [branchId], references: [id], onDelete: Cascade)
  products         CanteenProduct[]
  restockPurchases CanteenRestockPurchase[]
  payments         CanteenSupplierPayment[]

  @@unique([branchId, name])
  @@unique([id, branchId])
  @@index([branchId])
  @@map("canteen_suppliers")
}

model CanteenSupplierPayment {
  id          String                        @id @default(uuid())
  supplierId  String
  amount      Decimal                       @db.Decimal(12, 2)
  direction   CanteenSupplierPaymentDirection
  note        String?
  paidAt      DateTime                      @default(now())
  createdById String?

  supplier  CanteenSupplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  createdBy User?           @relation("CanteenSupplierPaymentCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([supplierId, paidAt])
  @@map("canteen_supplier_payments")
}

model CanteenProductCategory {
  id        String   @id @default(uuid())
  branchId  String
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  branch   Branch           @relation(fields: [branchId], references: [id], onDelete: Cascade)
  products CanteenProduct[]

  @@unique([branchId, name])
  @@unique([id, branchId])
  @@index([branchId])
  @@map("canteen_product_categories")
}

model CanteenProduct {
  id                String   @id @default(uuid())
  branchId          String
  categoryId        String
  supplierId        String?
  name              String
  unitPrice         Decimal  @db.Decimal(12, 2) // selling price per unit (PKR)
  boxPrice          Decimal? @db.Decimal(12, 2) // selling price per box (PKR)
  unitsPerBox       Int?     // units contained in one box
  stockBoxes        Int      @default(0)
  stockUnits        Int      @default(0) // loose units (0 .. unitsPerBox-1 when boxed)
  lowStockThreshold Int      @default(5) // alert when total units fall to or below
  isActive          Boolean  @default(true) // disable without deleting
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  createdById       String?
  updatedById       String?

  branch        Branch                 @relation(fields: [branchId], references: [id], onDelete: Cascade)
  category      CanteenProductCategory @relation(fields: [categoryId, branchId], references: [id, branchId], onDelete: Restrict)
  supplier      CanteenSupplier?       @relation(fields: [supplierId, branchId], references: [id, branchId], onDelete: SetNull)
  purchaseItems CanteenPurchaseItem[]
  saleItems     CanteenSaleItem[]

  @@unique([branchId, categoryId, name])
  @@unique([id, branchId])
  @@index([branchId])
  @@index([categoryId])
  @@index([supplierId])
  @@map("canteen_products")
}

model CanteenRestockPurchase {
  id           String   @id @default(uuid())
  branchId     String
  supplierId   String
  purchaseDate DateTime @default(now())
  totalCost    Decimal  @db.Decimal(12, 2)
  note         String?
  createdById  String?

  supplier  CanteenSupplier       @relation(fields: [supplierId, branchId], references: [id, branchId], onDelete: Restrict)
  branch    Branch                @relation(fields: [branchId], references: [id], onDelete: Cascade)
  items     CanteenPurchaseItem[]
  createdBy User?                 @relation("CanteenRestockCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([branchId, purchaseDate])
  @@index([supplierId])
  @@map("canteen_restock_purchases")
}

model CanteenPurchaseItem {
  id                String  @id @default(uuid())
  restockPurchaseId String
  productId         String
  quantity          Int
  unitCost          Decimal @db.Decimal(12, 2)

  restockPurchase CanteenRestockPurchase @relation(fields: [restockPurchaseId], references: [id], onDelete: Cascade)
  product         CanteenProduct         @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([productId])
  @@index([restockPurchaseId])
  @@map("canteen_purchase_items")
}

// Credit (bakaya) — MUST link a branch Student or branch staff User (no walk-in).
// App layer: student.academicYear.branchId === branchId; user must be active BranchMember.
model CanteenAccount {
  id             String            @id @default(uuid())
  branchId       String
  personType     CanteenPersonType
  studentId      String? // required when personType = STUDENT (DB check)
  userId         String? // required when personType = TEACHER | STAFF (DB check)
  displayName    String // snapshot from linked Student/User at account creation
  displayPhone   String? // snapshot only — not used to create accounts
  runningBalance Decimal           @default(0) @db.Decimal(12, 2)
  isActive       Boolean           @default(true)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  createdById    String?

  branch    Branch                  @relation(fields: [branchId], references: [id], onDelete: Cascade)
  student   Student?                @relation(fields: [studentId], references: [id], onDelete: Restrict)
  user      User?                   @relation("CanteenAccountUser", fields: [userId], references: [id], onDelete: Restrict)
  createdBy User?                   @relation("CanteenAccountCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  sales     CanteenSale[]
  payments  CanteenAccountPayment[]

  @@unique([branchId, studentId])
  @@unique([branchId, userId])
  @@unique([id, branchId])
  @@index([branchId, isActive])
  @@index([studentId])
  @@index([userId])
  @@map("canteen_accounts")
}

model CanteenAccountPayment {
  id               String   @id @default(uuid())
  canteenAccountId String
  amountPaid       Decimal  @db.Decimal(12, 2)
  paidAt           DateTime @default(now())
  note             String?
  createdById      String?

  account   CanteenAccount @relation(fields: [canteenAccountId], references: [id], onDelete: Cascade)
  createdBy User?          @relation("CanteenAccountPaymentCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([canteenAccountId, paidAt])
  @@map("canteen_account_payments")
}

model CanteenSale {
  id               String                 @id @default(uuid())
  branchId         String
  canteenAccountId String? // required when paymentType = CREDIT (DB check); null for CASH
  paymentType      CanteenSalePaymentType
  totalAmount      Decimal                @db.Decimal(12, 2)
  soldAt           DateTime               @default(now())
  createdById      String?

  branch    Branch            @relation(fields: [branchId], references: [id], onDelete: Cascade)
  account   CanteenAccount?   @relation(fields: [canteenAccountId, branchId], references: [id, branchId], onDelete: SetNull)
  createdBy User?             @relation("CanteenSaleCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  items     CanteenSaleItem[]

  @@unique([id, branchId])
  @@index([branchId, soldAt])
  @@index([canteenAccountId])
  @@map("canteen_sales")
}

model CanteenSaleItem {
  id              String  @id @default(uuid())
  saleId          String
  branchId        String
  productId       String
  quantity        Int
  unitPriceAtSale Decimal @db.Decimal(12, 2)

  sale    CanteenSale    @relation(fields: [saleId, branchId], references: [id, branchId], onDelete: Cascade)
  product CanteenProduct @relation(fields: [productId, branchId], references: [id, branchId], onDelete: Restrict)

  @@index([productId])
  @@index([saleId])
  @@map("canteen_sale_items")
}

model StationaryCategory {
  id        String   @id @default(uuid())
  branchId  String
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  branch   Branch             @relation(fields: [branchId], references: [id], onDelete: Cascade)
  products StationaryProduct[]

  @@unique([branchId, name])
  @@index([branchId])
  @@map("stationary_categories")
}

model StationarySupplier {
  id            String   @id @default(uuid())
  branchId      String
  name          String
  contactNumber String?
  note          String?
  balanceOwedToSupplier Decimal  @default(0) @db.Decimal(12, 2)
  balanceSupplierOwesUs Decimal  @default(0) @db.Decimal(12, 2)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  branch   Branch             @relation(fields: [branchId], references: [id], onDelete: Cascade)
  products StationaryProduct[]
  restockPurchases StationaryRestockPurchase[]
  payments StationarySupplierPayment[]

  @@unique([branchId, name])
  @@unique([id, branchId])
  @@index([branchId])
  @@map("stationary_suppliers")
}

model StationarySupplierPayment {
  id          String                            @id @default(uuid())
  supplierId  String
  amount      Decimal                           @db.Decimal(12, 2)
  direction   StationarySupplierPaymentDirection
  note        String?
  paidAt      DateTime                          @default(now())
  createdById String?

  supplier  StationarySupplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  createdBy User?              @relation("StationarySupplierPaymentCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([supplierId, paidAt])
  @@map("stationary_supplier_payments")
}

model StationaryProduct {
  id                String   @id @default(uuid())
  branchId          String
  categoryId        String
  supplierId        String?
  name              String
  unitPrice         Int // in paise
  bundlePrice       Int?
  unitsPerBundle    Int?
  stockBundles      Int      @default(0)
  stockUnits        Int      @default(0)
  lowStockThreshold Int      @default(10)
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  branch         Branch                    @relation(fields: [branchId], references: [id], onDelete: Cascade)
  category       StationaryCategory        @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  supplier       StationarySupplier?       @relation(fields: [supplierId, branchId], references: [id, branchId], onDelete: SetNull)
  stockMovements StationaryStockMovement[]
  recordItems    StudentStationaryRecordItem[]
  purchaseItems  StationaryPurchaseItem[]

  @@unique([branchId, categoryId, name])
  @@unique([id, branchId])
  @@index([branchId])
  @@index([categoryId])
  @@index([supplierId])
  @@map("stationary_products")
}

model StationaryRestockPurchase {
  id           String   @id @default(uuid())
  branchId     String
  supplierId   String
  purchaseDate DateTime @default(now())
  totalCost    Decimal  @db.Decimal(12, 2)
  note         String?
  createdById  String?

  supplier  StationarySupplier @relation(fields: [supplierId, branchId], references: [id, branchId], onDelete: Restrict)
  branch    Branch             @relation(fields: [branchId], references: [id], onDelete: Cascade)
  items     StationaryPurchaseItem[]
  createdBy User?              @relation("StationaryRestockCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([branchId, purchaseDate])
  @@index([supplierId])
  @@map("stationary_restock_purchases")
}

model StationaryPurchaseItem {
  id                String  @id @default(uuid())
  restockPurchaseId String
  productId         String
  quantity          Int
  unitCost          Decimal @db.Decimal(12, 2)

  restockPurchase StationaryRestockPurchase @relation(fields: [restockPurchaseId], references: [id], onDelete: Cascade)
  product         StationaryProduct         @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([productId])
  @@index([restockPurchaseId])
  @@map("stationary_purchase_items")
}

model StationaryStockMovement {
  id                  String                     @id @default(uuid())
  branchId            String
  productId           String
  movementType        StationaryStockMovementType
  quantityBundles     Int                        @default(0)
  quantityUnits       Int                        @default(0)
  unitPriceSnapshot   Int?
  note                String?
  studentRecordItemId String?
  createdById         String?
  createdAt           DateTime                   @default(now())

  branch            Branch                     @relation(fields: [branchId], references: [id], onDelete: Cascade)
  product           StationaryProduct          @relation(fields: [productId, branchId], references: [id, branchId], onDelete: Restrict)
  studentRecordItem StudentStationaryRecordItem? @relation(fields: [studentRecordItemId], references: [id], onDelete: SetNull)
  createdBy         User?                      @relation("StationaryStockMovementCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([branchId, createdAt])
  @@index([productId, createdAt])
  @@index([movementType])
  @@map("stationary_stock_movements")
}

model StudentStationaryRecord {
  id          String   @id @default(uuid())
  branchId    String
  studentId   String
  studentFeeId String?
  academicYearId String?
  note        String?
  createdById String?
  createdAt   DateTime @default(now())

  branch       Branch                      @relation(fields: [branchId], references: [id], onDelete: Cascade)
  student      Student                     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentFee   StudentFee?                 @relation(fields: [studentFeeId], references: [id], onDelete: SetNull)
  academicYear AcademicYear?               @relation(fields: [academicYearId], references: [id], onDelete: SetNull)
  createdBy    User?                       @relation("StudentStationaryRecordCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  items        StudentStationaryRecordItem[]

  @@index([branchId, createdAt])
  @@index([studentId, createdAt])
  @@index([studentFeeId])
  @@index([academicYearId])
  @@map("student_stationary_records")
}

model StudentStationaryRecordItem {
  id              String   @id @default(uuid())
  recordId        String
  productId       String
  productName     String
  categoryName    String?
  quantity        Int
  unitPrice       Int
  lineTotal       Int
  createdAt       DateTime @default(now())

  record          StudentStationaryRecord @relation(fields: [recordId], references: [id], onDelete: Cascade)
  product         StationaryProduct       @relation(fields: [productId], references: [id], onDelete: Restrict)
  feeExtraItems   FeeExtraItem[]
  stockMovements  StationaryStockMovement[]

  @@index([recordId])
  @@index([productId])
  @@map("student_stationary_record_items")
}

// ╔══════════════════════════════════════════════════════════════════╗
// ║              BRANCH EXPENSES / OUTGOING PAYMENTS                ║
// ║  Payroll (teachers + staff), utility bills, other expenses.    ║
// ║  Branch-scoped ledger — separate from student fee payments.     ║
// ╚══════════════════════════════════════════════════════════════════╝

model BranchExpenseCategory {
  id        String              @id @default(uuid())
  branchId  String
  kind      ExpenseCategoryKind
  name      String
  isActive  Boolean             @default(true)
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  branch            Branch              @relation(fields: [branchId], references: [id], onDelete: Cascade)
  utilityBills      UtilityBillDetail[]
  otherPayments     OtherPaymentDetail[]
  utilityProviders  UtilityProvider[]

  @@unique([branchId, kind, name])
  @@index([branchId, kind])
  @@map("branch_expense_categories")
}

model UtilityProvider {
  id             String   @id @default(uuid())
  branchId       String
  categoryId     String
  name           String
  consumerNumber String?
  contactNumber  String?
  note           String?
  reminderDayOfMonth Int?
  typicalAmount      Decimal? @db.Decimal(12, 2)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  branch   Branch                @relation(fields: [branchId], references: [id], onDelete: Cascade)
  category BranchExpenseCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  bills    UtilityBillDetail[]

  @@unique([branchId, name])
  @@index([branchId])
  @@index([categoryId])
  @@map("utility_providers")
}

model BranchOutgoingPayment {
  id            String                 @id @default(uuid())
  branchId      String
  type          OutgoingPaymentType
  amount        Decimal                @db.Decimal(12, 2)
  paymentMethod OutgoingPaymentMethod
  paidAt        DateTime               @default(now())
  reference     String?
  note          String?
  voucherNumber String
  status        OutgoingPaymentStatus  @default(PAID)
  voidedAt      DateTime?
  voidReason    String?
  voidedById    String?
  recordedById  String?
  bulkRunId     String?
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt

  branch         Branch                @relation(fields: [branchId], references: [id], onDelete: Cascade)
  recordedBy     User?                 @relation("OutgoingPaymentRecordedBy", fields: [recordedById], references: [id], onDelete: SetNull)
  voidedBy       User?                 @relation("OutgoingPaymentVoidedBy", fields: [voidedById], references: [id], onDelete: SetNull)
  bulkRun        PayrollBulkRun?       @relation(fields: [bulkRunId], references: [id], onDelete: SetNull)
  payrollDetail  PayrollPaymentDetail?
  utilityDetail  UtilityBillDetail?
  otherDetail    OtherPaymentDetail?

  @@unique([branchId, voucherNumber])
  @@index([branchId, type, paidAt])
  @@index([branchId, status])
  @@index([bulkRunId])
  @@map("branch_outgoing_payments")
}

model PayrollBulkRun {
  id            String                 @id @default(uuid())
  branchId      String
  salaryMonth   String
  paymentMethod OutgoingPaymentMethod
  paymentKind   PayrollPaymentKind     @default(REGULAR)
  totalAmount   Decimal                @db.Decimal(12, 2)
  successCount  Int
  failCount     Int
  note          String?
  recordedById  String?
  createdAt     DateTime               @default(now())

  branch     Branch                  @relation(fields: [branchId], references: [id], onDelete: Cascade)
  recordedBy User?                   @relation("PayrollBulkRunRecordedBy", fields: [recordedById], references: [id], onDelete: SetNull)
  payments   BranchOutgoingPayment[]

  @@index([branchId, salaryMonth])
  @@index([createdAt])
  @@map("payroll_bulk_runs")
}

model PayrollPaymentDetail {
  id                 String             @id @default(uuid())
  outgoingPaymentId  String             @unique
  payeeUserId        String
  payeeType          PayrollPayeeType
  salaryMonth        String // YYYY-MM
  paymentKind        PayrollPaymentKind @default(REGULAR)
  profileSalary      Decimal            @db.Decimal(12, 2)
  attendanceEarned   Decimal?           @db.Decimal(12, 2)
  openingBalance     Decimal            @default(0) @db.Decimal(12, 2)
  createdAt          DateTime           @default(now())

  outgoingPayment BranchOutgoingPayment @relation(fields: [outgoingPaymentId], references: [id], onDelete: Cascade)
  payee           User                  @relation("PayrollPayee", fields: [payeeUserId], references: [id], onDelete: Restrict)

  @@index([payeeUserId, salaryMonth])
  @@index([salaryMonth])
  @@map("payroll_payment_details")
}

model PayrollMonthBalance {
  id                 String           @id @default(uuid())
  branchId           String
  payeeUserId        String
  payeeType          PayrollPayeeType
  salaryMonth        String // YYYY-MM
  profileSalary      Decimal          @db.Decimal(12, 2)
  attendanceEarned   Decimal          @default(0) @db.Decimal(12, 2)
  extraDue           Decimal          @default(0) @db.Decimal(12, 2)
  openingBalance     Decimal          @default(0) @db.Decimal(12, 2)
  totalPaid          Decimal          @default(0) @db.Decimal(12, 2)
  closingBalance     Decimal          @default(0) @db.Decimal(12, 2)
  presentDays        Int              @default(0)
  absentDays         Int              @default(0)
  lateDays           Int              @default(0)
  leaveDays          Int              @default(0)
  unmarkedDays       Int              @default(0)
  workingDays        Int              @default(0)
  computedAt         DateTime?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([branchId, payeeUserId, salaryMonth])
  @@index([branchId, salaryMonth])
  @@map("payroll_month_balances")
}

model UtilityBillDetail {
  id                String             @id @default(uuid())
  outgoingPaymentId String             @unique
  categoryId        String
  providerId        String?
  providerName      String
  consumerNumber    String?
  billReference     String?
  periodStart       DateTime?          @db.Date
  periodEnd         DateTime?          @db.Date
  dueDate           DateTime?          @db.Date
  paymentKind       PayrollPaymentKind @default(REGULAR)
  createdAt         DateTime           @default(now())

  outgoingPayment BranchOutgoingPayment @relation(fields: [outgoingPaymentId], references: [id], onDelete: Cascade)
  category        BranchExpenseCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  provider        UtilityProvider?      @relation(fields: [providerId], references: [id], onDelete: SetNull)

  @@index([categoryId])
  @@index([providerId])
  @@map("utility_bill_details")
}

model OtherPaymentDetail {
  id                String             @id @default(uuid())
  outgoingPaymentId String             @unique
  categoryId        String
  payeeName         String
  description       String?
  paymentKind       PayrollPaymentKind @default(REGULAR)
  createdAt         DateTime           @default(now())

  outgoingPayment BranchOutgoingPayment @relation(fields: [outgoingPaymentId], references: [id], onDelete: Cascade)
  category        BranchExpenseCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  @@index([categoryId])
  @@map("other_payment_details")
}
