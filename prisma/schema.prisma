// Mother Care — School Management Platform
// Database Schema v2.0 — Academic Year System
// PostgreSQL + Prisma ORM

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ╔══════════════════════════════════════════════════════════════════╗
// ║                         ENUMERATIONS                            ║
// ╚══════════════════════════════════════════════════════════════════╝

enum Role {
  super_admin // Highest authority, full system access
  management // Administrative staff with assigned permissions
  teacher // Class/group instructors
  parent // Parent/student merged account
  student // Student login account
}

enum Gender {
  male
  female
  other
}

enum AccountStatus {
  active
  inactive
  suspended
}

// Branch-level roles for hierarchical access control
enum BranchRole {
  branch_admin // Principal — full branch management
  sub_admin // Vice-Principal / Deputy
  management // Accountant, Admin Staff
  teacher // Teaching staff
  parent // Parent representative
}

// Academic Year lifecycle: BUILD_STAGE → ACTIVE → ARCHIVED
enum AcademicYearStatus {
  BUILD_STAGE // Year being set up — only admins see it
  ACTIVE // Current operational year — everyone sees it
  ON_HOLD // Temporarily paused (e.g. summer break) — resume to ACTIVE
  ARCHIVED // Closed year — admins can still edit data
}

// Year-end close / batch promotion state machine
enum PromotionStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  REVERSED
  FAILED
}

// Student lifecycle status
enum StudentStatus {
  ACTIVE
  GRADUATED
  WITHDRAWN
  TRANSFERRED
  SUSPENDED
  EXPELED
  DECEASED
}

enum ApiKeyType {
  publishable // Public: verified store / registered layout
  secret // Admin: bypass login, full CRUD
}

enum ExamStatus {
  DRAFT
  ACTIVE
}

enum ReportCardStatus {
  DRAFT
  PUBLISHED
}

// ╔══════════════════════════════════════════════════════════════════╗
// ║                           USERS                                 ║
// ║  All credentials created by admin. No signup / forgot password. ║
// ╚══════════════════════════════════════════════════════════════════╝

model User {
  id               String        @id @default(uuid())
  schoolId         String?
  name             String
  username         String?       @unique
  email            String?       @unique
  phone            String?       @unique
  passwordHash     String
  role             Role          @default(parent)
  managementPerms  String[]      @default([])
  gender           Gender?
  dateOfBirth      DateTime?
  address          String?
  profilePhoto     String?
  profilePhotoId   String?       @unique
  profileFile      FileRecord?   @relation("UserProfilePhoto", fields: [profilePhotoId], references: [id])
  status           AccountStatus @default(active)
  isEmailVerified  Boolean       @default(false)
  isPhoneVerified  Boolean       @default(false)
  lastLoginAt      DateTime?
  lastSeen         DateTime?
  rememberMeToken  String?       @unique
  rememberMeExpiry DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  // Existing relations
  managementProfile   ManagementProfile?
  teacherProfile      TeacherProfile?
  parentProfile       ParentProfile?
  subjectsAsHod       Subject[]               @relation("SubjectHOD")
  sentMessages        Message[]               @relation("SentMessages")
  notifications       NotificationRecipient[]
  deviceTokens        DeviceToken[]
  auditLogs           AuditLog[]
  groupMembers        GroupMember[]
  batchPromotions     BatchPromotion[]        @relation("PromotedByUser")
  passwordResetTokens PasswordResetToken[]

  // New relations for Academic Year System
  branchMembers             BranchMember[]
  // Reverse relations for BranchMember.assignedBy and BranchMember.resignedInFavorOf
  assignedMembers           BranchMember[]         @relation("AssignedBy")
  resignedToMembers         BranchMember[]         @relation("ResignedInFavorOf")
  academicYearMembers       AcademicYearMember[]
  teacherAssignments        TeacherAssignment[]
  teacherAttendances        TeacherAttendance[]    @relation("TeacherAttendanceTeacher")
  academicYearSnapshots     AcademicYearSnapshot[] @relation("SnapshotTriggeredBy")
  timetableEntries          TimetableEntry[]       @relation("TimetableTeacher")
  uploadedFiles             FileRecord[]
  student                   Student?
  createdStudents           Student[]              @relation("StudentCreatedBy")
  updatedStudents           Student[]              @relation("StudentUpdatedBy")
  credentialSends           CredentialSend[]
  markedAttendances         Attendance[]
  teacherAttendanceMarkedBy TeacherAttendance[]    @relation("TeacherAttendanceMarkedBy")
  studentStatusChanges      StudentStatusLog[]
  feeChangeLogs             FeeChangeLog[]
  recordedPayments          Payment[]              @relation("PaymentRecordedBy")
  revertedPayments          Payment[]              @relation("PaymentRevertedBy")
  recordedFamilyPayments    FamilyPayment[]
  createdFamilies           Family[]           @relation("FamilyCreatedBy")
  updatedFamilies           Family[]           @relation("FamilyUpdatedBy")
  familyChangeLogs          FamilyChangeLog[]
  enteredMarks              MarksEntry[]           @relation("MarksEnteredBy")

  @@index([username])
  @@index([email])
  @@index([phone])
  @@index([role])
  @@index([status])
  @@map("users")
}

// ╔══════════════════════════════════════════════════════════════════╗
// ║                    FILE RECORD                                 ║
// ║  Universal file reference for profile photos, documents, etc.  ║
// ╚══════════════════════════════════════════════════════════════════╝

model FileRecord {
  id           String   @id @default(uuid())
  originalName String
  storagePath  String   @unique
  mimeType     String
  size         Int
  width        Int?
  height       Int?
  uploadedById String?
  entityType   String? // "student" | "teacher" — what entity this doc belongs to
  entityId     String? // UUID of the student or teacher profile
  createdAt    DateTime @default(now())

  uploader       User?    @relation(fields: [uploadedById], references: [id])
  profileUser    User?    @relation("UserProfilePhoto")
  profileStudent Student? @relation("StudentProfilePhoto")

  updatedAt DateTime @updatedAt

  @@index([entityType, entityId])
  @@map("file_records")
}

// ╔══════════════════════════════════════════════════════════════════╗
// ║                       SCHOOL / TENANT                           ║
// ║  Kept for backward compatibility (may be deprecated later).     ║
// ╚══════════════════════════════════════════════════════════════════╝

model School {
  id              String   @id @default(uuid())
  name            String
  address         String?
  phone           String?
  email           String?
  logoUrl         String?
  website         String?
  timezone        String   @default("Asia/Karachi")
  currency        String   @default("PKR")
  passingMarks    Float    @default(50.0)
  attendanceAlert Int      @default(75)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  createdById String?
  updatedById String?

  @@map("schools")
}

// ╔══════════════════════════════════════════════════════════════════╗
// ║                        BRANCH (Physical Campus)                 ║
// ║  A physical school campus or franchise location.               ║
// ║  Example: "Mother Care Sohan" (code: MCS-SOHAN)               ║
// ╚══════════════════════════════════════════════════════════════════╝

model Branch {
  id        String   @id @default(uuid())
  name      String   @unique
  code      String   @unique // Short code: "MCS-SOHAN"
  address   String?
  phone     String?
  email     String?
  logoUrl   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  academicYears    AcademicYear[]
  branchMembers    BranchMember[]
  adminInvitations AdminInvitation[]

  createdById String?
  updatedById String?

  @@map("branches")
}

// ╔══════════════════════════════════════════════════════════════════╗
// ║                   ACADEMIC CALENDAR                             ║
// ║  Shared reference: label ("2025-2026"), start/end dates.       ║
// ║  Decoupled from the container — multiple branches share the    ║
// ║  same calendar definition.                                     ║
// ╚══════════════════════════════════════════════════════════════════╝

model AcademicCalendar {
  id        String   @id @default(uuid())
  label     String   @unique // "2025-2026", "2026-2027"
  startDate DateTime
  endDate   DateTime
  isCurrent Boolean  @default(false) // Only one globally
  createdAt DateTime @default(now())

  academicYears AcademicYear[]

  updatedAt DateTime @updatedAt

  createdById String?
  updatedById String?

  @@map("academic_calendars")
}

// ╔══════════════════════════════════════════════════════════════════╗
// ║                      ACADEMIC YEAR                              ║
// ║  The core container — everything lives inside one.              ║
// ║  Lifecycle: BUILD_STAGE → ACTIVE → ARCHIVED                    ║
// ║  Exactly one ACTIVE per branch.                                 ║
// ╚══════════════════════════════════════════════════════════════════╝

model AcademicYear {
  id                     String             @id @default(uuid())
  branchId               String
  calendarId             String
  status                 AcademicYearStatus @default(BUILD_STAGE)
  previousAcademicYearId String? // Self-referencing FK for year chain
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt

  branch               Branch           @relation(fields: [branchId], references: [id], onDelete: Cascade)
  calendar             AcademicCalendar @relation(fields: [calendarId], references: [id])
  previousAcademicYear AcademicYear?    @relation("YearSequence", fields: [previousAcademicYearId], references: [id])
  nextAcademicYears    AcademicYear[]   @relation("YearSequence")

  members            AcademicYearMember[]
  groups             Group[]
  subjects           Subject[]
  teacherAssignments TeacherAssignment[]
  students           Student[]
  enrollments        Enrollment[]
  snapshots          AcademicYearSnapshot[] @relation("SourceAcademicYear")
  newSnapshots       AcademicYearSnapshot[] @relation("NewAcademicYear")
  announcements      Announcement[]
  timetables         Timetable[]
  attendances        Attendance[]
  teacherAttendances TeacherAttendance[]
  examSessions       ExamSession[]

  createdById   String?
  updatedById   String?
  feeStructures FeeStructure[]
  studentFees   StudentFee[]

  @@unique([branchId, calendarId])
  @@map("academic_years")
}

// ╔══════════════════════════════════════════════════════════════════╗
// ║                   ACADEMIC YEAR MEMBER                          ║
// ║  Links users to an academic year with a specific role.          ║
// ╚══════════════════════════════════════════════════════════════════╝

model AcademicYearMember {
  id             String @id @default(uuid())
  academicYearId String
  userId         String
  role           Role

  academicYear AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdById String?
  updatedById String?

  @@unique([academicYearId, userId])
  @@map("academic_year_members")
}

// ╔══════════════════════════════════════════════════════════════════╗
// ║                       BRANCH MEMBER                             ║
// ║  Links users to a branch (cross-year membership).               ║
// ╚══════════════════════════════════════════════════════════════════╝

model BranchMember {
  id                  String     @id @default(uuid())
  branchId            String
  userId              String
  role                BranchRole @default(teacher)
  isActive            Boolean    @default(true)
  keepTeacherRole     Boolean    @default(true)
  assignedById        String?
  resignedAt          DateTime?
  resignedInFavorOfId String?
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt

  branch            Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)
  user              User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignedBy        User?  @relation("AssignedBy", fields: [assignedById], references: [id])
  resignedInFavorOf User?  @relation("ResignedInFavorOf", fields: [resignedInFavorOfId], references: [id])

  createdById String?
  updatedById String?

  @@unique([branchId, userId])
  @@index([userId])
  @@map("branch_members")
}

// ╔══════════════════════════════════════════════════════════════════╗
// ║                     GROUPS (CLASSES / SECTIONS)                 ║
// ║  Represents a class + section within an academic year.          ║
// ║  Examples: "Playgroup", "Class 3-A", "Class 10-Bio"            ║
// ╚══════════════════════════════════════════════════════════════════╝

model Group {
  id               String   @id @default(uuid())
  academicYearId   String
  name             String // "Playgroup", "Class 3", "Class 10"
  section          String? // "A", "B" or "Bio", "CompSci", "Arts"
  displayOrder     Int // 1-13 for ordering/grade level
  capacity         Int      @default(30)
  onlyAdminCanSend Boolean  @default(true)
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  academicYear       AcademicYear        @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  members            GroupMember[]
  messages           Message[]
  students           Student[]
  groupSubjects      GroupSubject[]
  teacherAssignments TeacherAssignment[]
  enrollments        Enrollment[]
  timetableEntries   TimetableEntry[]
  examClasses        ExamClass[]

  createdById   String?
  updatedById   String?
  feeStructures FeeStructure[]
  studentFees   StudentFee[]

  @@unique([academicYearId, name, section])
  @@map("groups")
}

// Group membership (users in a group)
model GroupMember {
  id       String   @id @default(uuid())
  groupId  String
  userId   String
  role     Role
  joinedAt DateTime @default(now())

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdById String?
  updatedById String?

  @@unique([groupId, userId])
  @@map("group_members")
}

// ╔══════════════════════════════════════════════════════════════════╗
// ║                      SUBJECT                                    ║
// ║  Subjects exist at the AcademicYear level and are linked to     ║
// ║  specific groups via GroupSubject. One definition can be shared ║
// ║  across multiple groups/sections.                               ║
// ╚══════════════════════════════════════════════════════════════════╝

model Subject {
  id             String   @id @default(uuid())
  academicYearId String
  name           String // "English", "Mathematics", "Science"
  code           String? // Optional subject code (unique per AY)
  description    String?
  totalMarks     Float    @default(100)
  passingMarks   Float    @default(50)
  isElective     Boolean  @default(false)
  hodId          String? // Head of Department — FK to User
  createdAt      DateTime @default(now())

  academicYear       AcademicYear        @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  groupSubjects      GroupSubject[]
  teacherAssignments TeacherAssignment[]
  timetableEntries   TimetableEntry[]
  examClassSubjects  ExamClassSubject[]
  subjectResults     SubjectResult[]
  hod                User?               @relation("SubjectHOD", fields: [hodId], references: [id])

  updatedAt DateTime @updatedAt

  createdById String?
  updatedById String?

  @@unique([academicYearId, code])
  @@map("subjects")
}

// ╔══════════════════════════════════════════════════════════════════╗
// ║                    GROUP-SUBJECT LINKING                        ║
// ║  Links a subject to a specific group within an academic year.   ║
// ║  Enables sharing "English" across Class 1-A and Class 1-B.     ║
// ╚══════════════════════════════════════════════════════════════════╝

model GroupSubject {
  id        String @id @default(uuid())
  groupId   String
  subjectId String

  group   Group   @relation(fields: [groupId], references: [id], onDelete: Cascade)
  subject Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdById String?
  updatedById String?

  @@unique([groupId, subjectId])
  @@map("group_subjects")
}

// ╔══════════════════════════════════════════════════════════════════╗
// ║                     TEACHER PROFILE                             ║
// ║  Detailed profile for teacher role users.                       ║
// ╚══════════════════════════════════════════════════════════════════╝

model TeacherProfile {
  id               String    @id @default(uuid())
  userId           String    @unique
  employeeId       String?   @unique
  qualification    String?
  specialization   String?
  joiningDate      DateTime?
  salary           Decimal?  @db.Decimal(12, 2)
  phone            String?
  emergencyContact String?
  address          String?
  dateOfBirth      DateTime?
  gender           Gender?
  bloodGroup       String?
  fatherName       String?
  cardId           String?
  severeDisease    String?
  experience       String?
  bio              String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdById           String?
  updatedById           String?
  credentialGeneratedAt DateTime?
  credentialSentAt      DateTime?
  credentialDeliveredAt DateTime?
  credentialSeenAt      DateTime?
  passwordSetAt         DateTime?
  credentialStatus      String?   @default("none")

  @@map("teacher_profiles")
}

// ╔══════════════════════════════════════════════════════════════════╗
// ║                    TEACHER ASSIGNMENT                           ║
// ║  Assigns a teacher to teach a specific subject in a specific    ║
// ║  group during an academic year. isClassTeacher marks the homeroom ║
// ║  teacher for that group.                                        ║
// ╚══════════════════════════════════════════════════════════════════╝

model TeacherAssignment {
  id             String  @id @default(uuid())
  academicYearId String
  teacherId      String // FK → User (role=teacher)
  groupId        String
  subjectId      String
  isClassTeacher Boolean @default(false)
  role           String  @default("primary") // "primary", "assistant", "hod"

  academicYear AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  teacher      User         @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  group        Group        @relation(fields: [groupId], references: [id], onDelete: Cascade)
  subject      Subject      @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdById String?
  updatedById String?

  @@map("teacher_assignments")
}

// ╔══════════════════════════════════════════════════════════════════╗
// ║                    MANAGEMENT PROFILE                           ║
// ║  Track admin/management staff details.                         ║
// ╚══════════════════════════════════════════════════════════════════╝

model ManagementProfile {
  id          String    @id @default(uuid())
  userId      String    @unique
  employeeId  String?   @unique
  department  String?
  designation String?
  permissions String[]  @default([])
  joiningDate DateTime?
  salary      Decimal?  @db.Decimal(12, 2)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdById String?
  updatedById String?

  @@map("management_profiles")
}

// ╔══════════════════════════════════════════════════════════════════╗
// ║                      PARENT PROFILE                             ║
// ╚══════════════════════════════════════════════════════════════════╝

model ParentProfile {
  id            String   @id @default(uuid())
  userId        String   @unique
  occupation    String?
  employerName  String?
  maritalStatus String?
  monthlyIncome String?
  relation      String? // "Father", "Mother", "Guardian"
  cnicNumber    String?  @unique
  phone         String?
  whatsapp      String?
  email         String?
  createdAt     DateTime @default(now())

  user     User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  children StudentParent[]

  updatedAt DateTime @updatedAt

  createdById String?
  updatedById String?

  @@map("parent_profiles")
}

// ╔══════════════════════════════════════════════════════════════════╗
// ║                          STUDENT                                ║
// ║  Core student record. Current placement is groupId. Full        ║
// ║  history tracked via Enrollment model.                          ║
// ╚══════════════════════════════════════════════════════════════════╝

model Student {
  id                      String                   @id @default(uuid())
  academicYearId          String
  groupId                 String?
  familyId                String?
  name                    String
  rollNumber              String?
  admissionNumber         String?                  @unique
  dateOfBirth             DateTime?
  gender                  Gender?
  religion                String?
  nationality             String?                  @default("Pakistani")
  customFeeAmount         Int? // Per-student fee override (paise). Null = use class structure.
  concessionReason        String? // Reason: scholarship, discount, teachers child, etc.
  feeOverrides            Json? // Per-head overrides: {"headId": amount}
  address                 String?
  phone                   String?
  bloodGroup              String?
  bformCnic               String?
  motherTongue            String?
  studentEmail            String?
  studentWhatsapp         String?
  city                    String?
  postalCode              String?
  country                 String?
  previousSchool          String?
  previousClass           String?
  tcNumber                String?
  referredBy              String?
  profilePhotoId          String?                  @unique
  profileFile             FileRecord?              @relation("StudentProfilePhoto", fields: [profilePhotoId], references: [id])
  userId                  String?                  @unique
  user                    User?                    @relation(fields: [userId], references: [id], onDelete: SetNull)
  username                String?
  studentNumber           Int?                     @unique
  status                  StudentStatus            @default(ACTIVE)
  isActive                Boolean                  @default(true)
  admissionDate           DateTime                 @default(now())
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  createdById             String?
  updatedById             String?
  createdBy               User?                    @relation("StudentCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy               User?                    @relation("StudentUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  credentialGeneratedAt   DateTime?
  credentialSentAt        DateTime?
  credentialDeliveredAt   DateTime?
  credentialSeenAt        DateTime?
  passwordSetAt           DateTime?
  credentialStatus        String?                  @default("none")
  credentialSends         CredentialSend[]
  statusLogs              StudentStatusLog[]
  attendanceNotifications AttendanceNotification[]

  academicYear      AcademicYear       @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  group             Group?             @relation(fields: [groupId], references: [id], onDelete: SetNull)
  family            Family?            @relation("StudentFamily", fields: [familyId], references: [id], onDelete: SetNull)
  parents           StudentParent[]
  enrollments       Enrollment[]
  emergencyContacts EmergencyContact[]
  healthRecord      HealthRecord?
  attendances       Attendance[]
  studentFees       StudentFee[]
  feePayments       Payment[]          @relation("PaymentStudent")
  examMarks         MarksEntry[]
  subjectResults    SubjectResult[]
  reportCards       ReportCard[]

  @@index([groupId])
  @@index([familyId])
  @@index([academicYearId])
  @@map("students")
}

// ─── Attendance (one row per student per day per AY) ─────────
model Attendance {
  id             String   @id @default(uuid())
  studentId      String
  academicYearId String
  date           DateTime @db.Date
  status         String // "present" | "absent" | "late" | "leave" | "holiday" | "function"
  note           String?
  markedById     String?

  student      Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  academicYear AcademicYear @relation(fields: [academicYearId], references: [id])
  markedBy     User?        @relation(fields: [markedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([studentId, date])
  @@index([academicYearId, date])
  @@map("attendances")
}

model TeacherAttendance {
  id             String   @id @default(uuid())
  teacherId      String
  academicYearId String
  date           DateTime @db.Date
  status         String // "present" | "absent" | "late" | "leave" | "holiday" | "function"
  note           String?
  markedById     String?

  teacher      User         @relation("TeacherAttendanceTeacher", fields: [teacherId], references: [id], onDelete: Cascade)
  academicYear AcademicYear @relation(fields: [academicYearId], references: [id])
  markedBy     User?        @relation("TeacherAttendanceMarkedBy", fields: [markedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([teacherId, date])
  @@index([academicYearId, date])
  @@map("teacher_attendances")
}

// Credential send history (redacted — no passwords stored)
model CredentialSend {
  id          String    @id @default(uuid())
  studentId   String
  sentAt      DateTime  @default(now())
  deliveredAt DateTime?
  seenAt      DateTime?
  status      String // "sent" | "delivered" | "read" | "failed"
  to          String? // Masked phone: "03XX-XXXXXX"
  errorMsg    String?
  sentById    String?

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  sentBy  User?   @relation(fields: [sentById], references: [id])

  @@index([studentId])
  @@map("credential_sends")
}

// Student-Parent linking (many-to-many)
model StudentParent {
  id        String   @id @default(uuid())
  studentId String
  parentId  String
  relation  String // "Father", "Mother", "Guardian"
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())

  student Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  parent  ParentProfile @relation(fields: [parentId], references: [id], onDelete: Cascade)

  updatedAt DateTime @updatedAt

  createdById String?
  updatedById String?

  @@unique([studentId, parentId])
  @@map("student_parents")
}

// ╔══════════════════════════════════════════════════════════════════╗
// ║                    EMERGENCY CONTACT                             ║
// ╚══════════════════════════════════════════════════════════════════╝

model EmergencyContact {
  id           String   @id @default(uuid())
  studentId    String
  name         String
  relationship String
  phone        String
  whatsapp     String?
  priority     Int      @default(1)
  createdAt    DateTime @default(now())

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  updatedAt DateTime @updatedAt

  createdById String?
  updatedById String?

  @@map("emergency_contacts")
}

// ╔══════════════════════════════════════════════════════════════════╗
// ║                      HEALTH RECORD                              ║
// ║  One record per student.                                        ║
// ╚══════════════════════════════════════════════════════════════════╝

model HealthRecord {
  id                String   @id @default(uuid())
  studentId         String   @unique
  bloodGroup        String?
  hasChronicDisease Boolean  @default(false)
  diseaseDetails    String?
  allergies         String?
  disability        String?
  medicalNotes      String?
  doctorName        String?
  doctorPhone       String?
  updatedAt         DateTime @updatedAt

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  createdById String?
  updatedById String?

  @@map("health_records")
}

// ╔══════════════════════════════════════════════════════════════════╗
// ║                       ENROLLMENT                                ║
// ║  One record per student per academic year. Immutable after      ║
// ║  creation (only leftAt can be set at year-end close).           ║
// ╚══════════════════════════════════════════════════════════════════╝

model Enrollment {
  id             String    @id @default(uuid())
  studentId      String
  academicYearId String
  groupId        String
  rollNumber     String?
  joinedAt       DateTime  @default(now())
  leftAt         DateTime?

  student      Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  academicYear AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  group        Group        @relation(fields: [groupId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdById String?
  updatedById String?

  @@unique([studentId, academicYearId])
  @@map("enrollments")
}

// ╔══════════════════════════════════════════════════════════════════╗
// ║                    ACADEMIC YEAR SNAPSHOT                       ║
// ║  Records a year-end close / batch promotion event. Contains     ║
// ║  frozen snapshot of all groups within the academic year.        ║
// ╚══════════════════════════════════════════════════════════════════╝

model AcademicYearSnapshot {
  id                String          @id @default(uuid())
  academicYearId    String
  newAcademicYearId String?
  fromLabel         String // Human label of source year
  toLabel           String // Human label of target year
  triggeredById     String // User who triggered the close
  status            PromotionStatus @default(PENDING)
  totalStudents     Int             @default(0)
  totalGraduated    Int             @default(0)
  canReverse        Boolean         @default(true)
  reversedAt        DateTime?
  createdAt         DateTime        @default(now())

  academicYear    AcademicYear    @relation("SourceAcademicYear", fields: [academicYearId], references: [id], onDelete: Cascade)
  newAcademicYear AcademicYear?   @relation("NewAcademicYear", fields: [newAcademicYearId], references: [id])
  triggeredBy     User            @relation("SnapshotTriggeredBy", fields: [triggeredById], references: [id])
  groupSnapshots  GroupSnapshot[]

  updatedAt DateTime @updatedAt

  createdById String?
  updatedById String?

  @@map("academic_year_snapshots")
}

// ╔══════════════════════════════════════════════════════════════════╗
// ║                      GROUP SNAPSHOT                             ║
// ║  Frozen state of a group at year-end close time.                ║
// ║  studentsData and teachersData are JSON snapshots.              ║
// ╚══════════════════════════════════════════════════════════════════╝

model GroupSnapshot {
  id           String  @id @default(uuid())
  snapshotId   String
  groupId      String // Original group ID (not FK — group may change)
  groupName    String
  section      String?
  displayOrder Int
  studentsData Json? // Frozen student list
  teachersData Json? // Frozen teacher assignments
  studentCount Int     @default(0)

  snapshot AcademicYearSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdById String?
  updatedById String?

  @@map("group_snapshots")
}

// ╔══════════════════════════════════════════════════════════════════╗
// ║                    ANNOUNCEMENTS                                ║
// ╚══════════════════════════════════════════════════════════════════╝

model Announcement {
  id             String   @id @default(uuid())
  academicYearId String
  senderId       String
  title          String
  content        String?
  mediaUrl       String?
  isPinned       Boolean  @default(false)
  createdAt      DateTime @default(now())

  academicYear AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)

  updatedAt DateTime @updatedAt

  @@index([academicYearId, createdAt])
  @@map("announcements")
}

// ╔══════════════════════════════════════════════════════════════════╗
// ║                     MESSAGES (GROUP CHAT)                       ║
// ╚══════════════════════════════════════════════════════════════════╝

model Message {
  id        String   @id @default(uuid())
  groupId   String
  senderId  String
  content   String?
  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  group  Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  sender User  @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([groupId, createdAt])
  @@map("messages")
}

// Attendance notifications for parents (queued for chat app pickup)
model AttendanceNotification {
  id        String    @id @default(uuid())
  studentId String
  date      DateTime  @db.Date
  status    String
  message   String
  sent      Boolean   @default(false)
  sentAt    DateTime?
  createdAt DateTime  @default(now())

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([sent])
  @@map("attendance_notifications")
}

// ╔══════════════════════════════════════════════════════════════════╗
// ║                    BATCH PROMOTION                              ║
// ║  Promote all students from current class to next.              ║
// ║  Will be fully reworked in Phase 12.                           ║
// ╚══════════════════════════════════════════════════════════════════╝

model BatchPromotion {
  id             String    @id @default(uuid())
  academicYearId String
  fromYear       String
  toYear         String
  promotedById   String
  status         String    @default("pending")
  totalStudents  Int
  canReverse     Boolean   @default(true)
  reversedAt     DateTime?
  notes          String?
  createdAt      DateTime  @default(now())

  promotedBy User @relation("PromotedByUser", fields: [promotedById], references: [id])

  updatedAt DateTime @updatedAt

  createdById String?
  updatedById String?

  @@map("batch_promotions")
}

// ╔══════════════════════════════════════════════════════════════════╗
// ║                    NOTIFICATION SYSTEM                          ║
// ╚══════════════════════════════════════════════════════════════════╝

model NotificationRecipient {
  id        String    @id @default(uuid())
  userId    String
  title     String
  body      String
  type      String // "announcement", "message", etc.
  data      Json?
  isRead    Boolean   @default(false)
  readAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  updatedAt DateTime @updatedAt

  @@index([userId, isRead])
  @@map("notification_recipients")
}

// Device tokens for push notifications
model DeviceToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  platform  String // "android", "ios", "web"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("device_tokens")
}

// ╔══════════════════════════════════════════════════════════════════╗
// ║                    PASSWORD RESET TOKENS                        ║
// ╚══════════════════════════════════════════════════════════════════╝

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id])

  updatedAt DateTime @updatedAt

  @@index([token])
  @@map("password_reset_tokens")
}

// ╔══════════════════════════════════════════════════════════════════╗
// ║                    EXAM & GRADES MODULE                         ║
// ╚══════════════════════════════════════════════════════════════════╝

model ExamType {
  id            String   @id @default(uuid())
  name          String
  defaultWeight Float?
  examSessionId String
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  createdById String?
  updatedById String?

  examSession ExamSession @relation(fields: [examSessionId], references: [id], onDelete: Cascade)
  exams       Exam[]

  @@unique([examSessionId, name])
  @@index([examSessionId])
  @@map("exam_types")
}

model ExamSession {
  id             String   @id @default(uuid())
  name           String
  academicYearId String
  startDate      DateTime
  endDate        DateTime
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  createdById String?
  updatedById String?

  academicYear   AcademicYear    @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  examTypes      ExamType[]
  exams          Exam[]
  subjectResults SubjectResult[]
  reportCards    ReportCard[]

  @@index([academicYearId])
  @@map("exam_sessions")
}

model Exam {
  id             String     @id @default(uuid())
  examSessionId  String
  examTypeId     String
  name           String
  weightOverride Float?
  startDate      DateTime
  endDate        DateTime?
  status         ExamStatus @default(DRAFT)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  createdById String?
  updatedById String?

  examSession ExamSession @relation(fields: [examSessionId], references: [id], onDelete: Cascade)
  examType    ExamType    @relation(fields: [examTypeId], references: [id])
  examClasses ExamClass[]

  @@index([examSessionId])
  @@index([examTypeId])
  @@map("exams")
}

model ExamClass {
  id        String   @id @default(uuid())
  examId    String
  classId   String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdById String?
  updatedById String?

  exam     Exam               @relation(fields: [examId], references: [id], onDelete: Cascade)
  class    Group              @relation(fields: [classId], references: [id])
  subjects ExamClassSubject[]

  @@unique([examId, classId])
  @@index([classId])
  @@map("exam_classes")
}

model ExamClassSubject {
  id           String   @id @default(uuid())
  examClassId  String
  subjectId    String
  isActive     Boolean  @default(true)
  totalMarks   Int?
  passingMarks Int?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  createdById String?
  updatedById String?

  examClass    ExamClass    @relation(fields: [examClassId], references: [id], onDelete: Cascade)
  subject      Subject      @relation(fields: [subjectId], references: [id])
  marksEntries MarksEntry[]

  @@unique([examClassId, subjectId])
  @@index([subjectId])
  @@map("exam_class_subjects")
}

model MarksEntry {
  id                 String   @id @default(uuid())
  examClassSubjectId String
  studentId          String
  marksObtained      Float?
  isAbsent           Boolean  @default(false)
  enteredBy          String
  enteredAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  createdById String?
  updatedById String?

  examClassSubject ExamClassSubject @relation(fields: [examClassSubjectId], references: [id], onDelete: Cascade)
  student          Student          @relation(fields: [studentId], references: [id])
  enteredByUser    User             @relation("MarksEnteredBy", fields: [enteredBy], references: [id], onDelete: SetNull)

  @@unique([examClassSubjectId, studentId])
  @@index([studentId])
  @@index([enteredBy])
  @@map("marks_entries")
}

model GradeScale {
  id        String   @id @default(uuid())
  name      String
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdById String?
  updatedById String?

  bands GradeBand[]

  @@map("grade_scales")
}

model GradeBand {
  id           String   @id @default(uuid())
  gradeScaleId String
  minPercent   Float
  maxPercent   Float
  label        String
  gpa          Float?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  createdById String?
  updatedById String?

  gradeScale GradeScale @relation(fields: [gradeScaleId], references: [id], onDelete: Cascade)

  @@index([gradeScaleId])
  @@map("grade_bands")
}

model SubjectResult {
  id            String   @id @default(uuid())
  studentId     String
  examSessionId String
  subjectId     String
  percentage    Float
  grade         String
  subjectRank   Int?
  computedAt    DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  createdById String?
  updatedById String?

  student     Student     @relation(fields: [studentId], references: [id])
  examSession ExamSession @relation(fields: [examSessionId], references: [id], onDelete: Cascade)
  subject     Subject     @relation(fields: [subjectId], references: [id])

  @@unique([studentId, examSessionId, subjectId])
  @@index([examSessionId])
  @@index([subjectId])
  @@map("subject_results")
}

model ReportCard {
  id                String           @id @default(uuid())
  studentId         String
  examSessionId     String
  overallPercentage Float
  overallGrade      String
  classRank         Int?
  pdfUrl            String?
  status            ReportCardStatus @default(DRAFT)
  generatedAt       DateTime         @default(now())
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  createdById String?
  updatedById String?

  student     Student     @relation(fields: [studentId], references: [id])
  examSession ExamSession @relation(fields: [examSessionId], references: [id], onDelete: Cascade)

  @@unique([studentId, examSessionId])
  @@index([examSessionId])
  @@map("report_cards")
}

// ╔══════════════════════════════════════════════════════════════════╗
// ║                       AUDIT TRAIL                               ║
// ╚══════════════════════════════════════════════════════════════════╝

model AuditLog {
  id        String   @id @default(uuid())
  userId    String? // nullable — system events and deleted-user scenarios must never break the audit trail
  action    String
  entity    String
  entityId  String?
  oldValue  Json?
  newValue  Json?
  metadata  Json?
  ipAddress String?
  userAgent String?
  module    String   @default("system")
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  updatedAt DateTime @updatedAt

  @@index([userId, createdAt])
  @@index([entity, entityId])
  @@index([module, entity, entityId])
  @@map("audit_logs")
}

// ╔══════════════════════════════════════════════════════════════════╗
// ║                         API KEYS                                ║
// ╚══════════════════════════════════════════════════════════════════╝

model ApiKey {
  id         String     @id @default(uuid())
  name       String
  type       ApiKeyType @default(publishable)
  keyHash    String     @unique
  prefix     String // e.g. "mcs_abc1"
  createdBy  String
  lastUsedAt DateTime?
  expiresAt  DateTime?
  revokedAt  DateTime?
  createdAt  DateTime   @default(now())

  updatedAt DateTime @updatedAt

  @@index([prefix])
  @@index([revokedAt])
  @@index([type])
  @@map("api_keys")
}

// ╔══════════════════════════════════════════════════════════════════╗
// ║                     ADMIN INVITATIONS                           ║
// ╚══════════════════════════════════════════════════════════════════╝

model AdminInvitation {
  id        String    @id @default(uuid())
  email     String
  name      String?
  phone     String?
  branchId  String
  token     String    @unique
  usedAt    DateTime?
  expiresAt DateTime
  createdAt DateTime  @default(now())

  branch Branch @relation(fields: [branchId], references: [id])

  updatedAt DateTime @updatedAt

  createdById String?
  updatedById String?

  @@index([token])
  @@index([email])
  @@index([branchId])
  @@map("admin_invitations")
}

// ╔══════════════════════════════════════════════════════════════════╗
// ║                   TIMETABLE SLOTS                               ║
// ║  Universal time grid for all classes within an academic year.  ║
// ║  Defines the lecture periods (start-end time) for each day.    ║
// ╚══════════════════════════════════════════════════════════════════╝

// ╔══════════════════════════════════════════════════════════════════╗
// ║              TIMETABLE (parent entity)                          ║
// ║  Each timetable/datesheet has its own ID, name, type.          ║
// ║  Slots, day configs, and entries all reference this ID.        ║
// ╚══════════════════════════════════════════════════════════════════╝

model Timetable {
  id             String   @id @default(uuid())
  academicYearId String
  name           String // Display name (regular, friday-schedule, exam-week)
  type           String   @default("timetable") // "timetable" or "datesheet"
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())

  academicYear AcademicYear         @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  slots        TimetableSlot[]
  dayConfigs   TimetableDayConfig[]

  updatedAt DateTime @updatedAt

  createdById String?
  updatedById String?

  @@unique([academicYearId, name])
  @@map("timetables")
}

model TimetableSlot {
  id            String   @id @default(uuid())
  timetableId   String
  dayOfWeek     Int? // null = all days, 1=Monday ... 6=Saturday
  lectureNumber Int // 1, 2, 3...
  startTime     String // "08:00"
  endTime       String // "08:40"
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())

  timetable Timetable        @relation(fields: [timetableId], references: [id], onDelete: Cascade)
  entries   TimetableEntry[]

  updatedAt DateTime @updatedAt

  createdById String?
  updatedById String?

  @@unique([timetableId, lectureNumber])
  @@map("timetable_slots")
}

// ╔══════════════════════════════════════════════════════════════════╗
// ║                   TIMETABLE ENTRIES                             ║
// ║  Links a slot → section → subject + teacher.                   ║
// ║  One entry per slot per section.                               ║
// ╚══════════════════════════════════════════════════════════════════╝

model TimetableEntry {
  id        String  @id @default(uuid())
  slotId    String
  groupId   String // FK → Group (section)
  subjectId String?
  teacherId String?
  note      String? // "break", etc.

  slot    TimetableSlot @relation(fields: [slotId], references: [id], onDelete: Cascade)
  group   Group         @relation(fields: [groupId], references: [id], onDelete: Cascade)
  subject Subject?      @relation(fields: [subjectId], references: [id])
  teacher User?         @relation("TimetableTeacher", fields: [teacherId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdById String?
  updatedById String?

  @@unique([slotId, groupId])
  @@map("timetable_entries")
}

// ╔══════════════════════════════════════════════════════════════════╗
// ║              TIMETABLE DAY CONFIG                               ║
// ║  Stores which days are active per timetable.                   ║
// ╚══════════════════════════════════════════════════════════════════╝

model TimetableDayConfig {
  id          String   @id @default(uuid())
  timetableId String
  dayOfWeek   Int // 1=Mon ... 6=Sat
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  timetable Timetable @relation(fields: [timetableId], references: [id], onDelete: Cascade)

  updatedAt DateTime @updatedAt

  createdById String?
  updatedById String?

  @@unique([timetableId, dayOfWeek])
  @@map("timetable_day_configs")
}

// ╔══════════════════════════════════════════════════════════════════╗
// ║                    STUDENT STATUS LOG                            ║
// ║  Tracks every status change with reason and who changed it.     ║
// ╚══════════════════════════════════════════════════════════════════╝

model StudentStatusLog {
  id             String         @id @default(uuid())
  studentId      String
  previousStatus StudentStatus?
  newStatus      StudentStatus
  reason         String?
  changedById    String?
  createdAt      DateTime       @default(now())

  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  changedBy User?   @relation(fields: [changedById], references: [id])

  @@index([studentId])
  @@map("student_status_logs")
}

// ╔══════════════════════════════════════════════════════════════════╗
// ║                     FEE / PAYMENT SYSTEM                        ║
// ║  Family grouping, fee heads, structures, student fees,          ║
// ║  payments, receipts, and sibling combined payments.             ║
// ╚══════════════════════════════════════════════════════════════════╝

model Family {
  id         String   @id @default(uuid())
  name       String
  fatherName String?
  motherName String?
  phone      String?
  address    String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  createdById String?
  updatedById String?

  students   Student[]         @relation("StudentFamily")
  payments   FamilyPayment[]
  changeLogs FamilyChangeLog[]
  createdBy  User?             @relation("FamilyCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy  User?             @relation("FamilyUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  @@index([name])
  @@index([isActive])
  @@index([createdById])
  @@map("families")
}

// Tracks family membership and profile changes (student add/remove, deactivation, etc.)
model FamilyChangeLog {
  id          String   @id @default(uuid())
  familyId    String
  action      String   // CREATED | UPDATED | STUDENT_ADDED | STUDENT_REMOVED | DEACTIVATED | REACTIVATED
  details     Json?
  changedById String?
  createdAt   DateTime @default(now())

  family    Family @relation(fields: [familyId], references: [id], onDelete: Cascade)
  changedBy User?  @relation(fields: [changedById], references: [id], onDelete: SetNull)

  @@index([familyId])
  @@index([changedById])
  @@map("family_change_logs")
}

model FeeHead {
  id          String   @id @default(uuid())
  name        String // Tuition, Transport, Lab, Library, etc.
  description String?
  isOptional  Boolean  @default(false)
  isActive    Boolean  @default(true)
  category    String   @default("MONTHLY") // MONTHLY | TERM | ANNUAL | ONE_TIME
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  structures      FeeStructure[]
  headAllocations PaymentHeadAllocation[]

  @@map("fee_heads")
}

model FeeStructure {
  id             String    @id @default(uuid())
  academicYearId String
  groupId        String
  feeHeadId      String
  amount         Int // In paise (500000 = 5000 PKR)
  effectiveFrom  DateTime  @default(now())
  effectiveTo    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  academicYear AcademicYear   @relation(fields: [academicYearId], references: [id])
  group        Group          @relation(fields: [groupId], references: [id])
  feeHead      FeeHead        @relation(fields: [feeHeadId], references: [id])
  changeLogs   FeeChangeLog[]

  @@unique([academicYearId, groupId, feeHeadId, effectiveFrom])
  @@index([academicYearId, groupId])
  @@map("fee_structures")
}

model FeeChangeLog {
  id             String   @id @default(uuid())
  feeStructureId String
  previousAmount Int
  newAmount      Int
  reason         String?
  changedById    String
  changedAt      DateTime @default(now())

  feeStructure FeeStructure @relation(fields: [feeStructureId], references: [id])
  changedBy    User         @relation(fields: [changedById], references: [id])

  @@index([feeStructureId])
  @@map("fee_change_logs")
}

model StudentFee {
  id               String    @id @default(uuid())
  academicYearId   String
  studentId        String
  groupId          String? // Snapshot of class at generation time
  month            Int // 1-12
  year             Int
  totalAmount      Int // Sum of all applicable heads (paise)
  concession       Int       @default(0)
  lateFee          Int       @default(0)
  netAmount        Int // totalAmount - concession + lateFee
  extraCharges     Int       @default(0) // Additional charges on top of base fee
  extraReason      String? // Reason for extra charges
  paidAmount       Int       @default(0)
  feeHeadBreakdown Json? // Array of {name, amount, category} from generation
  status           String    @default("UNPAID") // UNPAID | PARTIAL | PAID | OVERPAID | WAIVED
  dueDate          DateTime?
  paidAt           DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  academicYear    AcademicYear            @relation(fields: [academicYearId], references: [id])
  student         Student                 @relation(fields: [studentId], references: [id])
  group           Group?                  @relation(fields: [groupId], references: [id])
  payments        Payment[]
  extraItems      FeeExtraItem[]
  headAllocations PaymentHeadAllocation[]

  @@unique([studentId, month, year, academicYearId])
  @@index([month, year, status])
  @@index([academicYearId, status])
  @@map("student_fees")
}

model FeeExtraItem {
  id           String   @id @default(uuid())
  studentFeeId String
  name         String
  amount       Int // in paise
  createdAt    DateTime @default(now())

  studentFee      StudentFee              @relation(fields: [studentFeeId], references: [id], onDelete: Cascade)
  headAllocations PaymentHeadAllocation[]

  @@index([studentFeeId])
  @@map("fee_extra_items")
}

model FamilyPayment {
  id            String   @id @default(uuid())
  familyId      String
  academicYearId String?
  receiptNumber String   @unique // FMP-YYYYMM-XXXX
  totalAmount   Int
  paymentMethod String?
  reference     String?
  note          String?
  paymentDate   DateTime @default(now())
  recordedById  String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  family     Family    @relation(fields: [familyId], references: [id])
  payments   Payment[]
  receipt    FamilyPaymentReceipt?
  recordedBy User      @relation(fields: [recordedById], references: [id])

  @@index([familyId])
  @@index([academicYearId])
  @@map("family_payments")
}

// Combined family receipt snapshot — one per FamilyPayment (FMP-…)
model FamilyPaymentReceipt {
  id                String   @id @default(uuid())
  familyPaymentId   String   @unique
  receiptNumber     String
  templateType      String   // FIRST | ARREARS | CONTINUATION
  snapshot          Json     // Full receipt payload for print/reprint
  totalDuePaise     Int
  amountPaidPaise   Int
  balanceAfterPaise Int
  paymentMethod     String?
  reference         String?
  paymentDate       DateTime
  printedAt         DateTime?
  printCount        Int      @default(0)
  createdAt         DateTime @default(now())

  familyPayment FamilyPayment @relation(fields: [familyPaymentId], references: [id], onDelete: Cascade)

  @@index([receiptNumber])
  @@map("family_payment_receipts")
}

model Payment {
  id              String    @id @default(uuid())
  studentFeeId    String
  studentId       String
  familyPaymentId String?
  amount          Int // In paise
  paymentMethod   String // CASH | CHEQUE | BANK_TRANSFER
  receiptNumber   String    @unique // RCP-YYYYMM-XXXX
  reference       String? // Cheque number / transaction ID
  paymentDate     DateTime  @default(now())
  recordedById    String
  note            String?
  revertedAt      DateTime?
  revertedById    String?
  revertReason    String?
  createdAt       DateTime  @default(now())

  studentFee      StudentFee              @relation(fields: [studentFeeId], references: [id])
  student         Student                 @relation("PaymentStudent", fields: [studentId], references: [id], onDelete: Cascade)
  familyPayment   FamilyPayment?          @relation(fields: [familyPaymentId], references: [id])
  receipt         PaymentReceipt? // One immutable receipt per payment
  auditLogs       PaymentAuditLog[]
  headAllocations PaymentHeadAllocation[]

  recordedBy User  @relation("PaymentRecordedBy", fields: [recordedById], references: [id])
  revertedBy User? @relation("PaymentRevertedBy", fields: [revertedById], references: [id])

  @@index([studentFeeId])
  @@index([familyPaymentId])
  @@index([receiptNumber])
  @@index([studentId])
  @@map("payments")
}

// ─── Payment Head Allocation ────────────────────────────────────────
// Head/extra-level split of a single Payment, for the manual allocation
// flow (Step 1 UI: accountant selects specific fee heads and extras
// within the current month, plus whole previous months). Only current-
// month payments get rows here — previous months stay whole, never split
// by head, matching the UI (previous months have no sub-cat checkboxes).
// Exactly one of feeHeadId / feeExtraItemId is set per row, never both,
// never neither.
model PaymentHeadAllocation {
  id             String    @id @default(uuid())
  paymentId      String
  studentFeeId   String
  feeHeadId      String?
  feeExtraItemId String?
  amount         Int // in paise
  revertedAt     DateTime?
  createdAt      DateTime  @default(now())

  payment      Payment       @relation(fields: [paymentId], references: [id])
  studentFee   StudentFee    @relation(fields: [studentFeeId], references: [id])
  feeHead      FeeHead?      @relation(fields: [feeHeadId], references: [id])
  feeExtraItem FeeExtraItem? @relation(fields: [feeExtraItemId], references: [id])

  @@index([paymentId])
  @@index([studentFeeId])
  @@index([feeHeadId])
  @@index([feeExtraItemId])
  @@map("payment_head_allocations")
}

// ─── Receipt Snapshot ───────────────────────────────────────────────
// Stores exactly what was shown on the receipt at payment time.
// One snapshot per Payment. Immutable after creation.
model PaymentReceipt {
  id            String @id @default(uuid())
  paymentId     String @unique
  receiptNumber String // Denormalized for fast lookup

  // Current month (the one being paid) — full breakdown
  currentMonthLabel  String // "Jun 2026"
  currentMonthTotal  Int // in paise
  currentMonthHeads  Json // [{name:"Tuition", amount:300000}, ...]
  currentMonthExtras Json? // [{name:"Lab", amount:50000}, ...]

  // Previous months — one combined line
  previousBalancePaise Int // sum of what was due from earlier months
  previousMonthsCount  Int // how many months in the previous balance
  // Per-month arrears detail — [{label, dueBeforePaise, paidPaise, remainingPaise}, ...]
  previousMonths Json?

  // FIRST | ARREARS | CONTINUATION — mirrors family receipt templates
  templateType String?

  // Per-month allocation breakdown for waterfall/family payments that span
  // multiple months in one transaction — [{label:"Jun 2026", amountPaise:50000}, ...]
  // Null/empty for single-fee payments (currentMonth section covers it alone).
  allocations Json?

  // Summary
  totalDuePaise     Int // currentMonthTotal + previousBalancePaise
  amountPaidPaise   Int // what this payment covered
  balanceAfterPaise Int // remaining after this payment

  // Context at time of payment
  paymentMethod String
  reference     String?
  studentName   String
  studentClass  String
  studentRoll   String?
  fatherName    String?
  isFullyPaid   Boolean

  // Audit
  paymentDate DateTime
  printedAt   DateTime? // first print timestamp
  printCount  Int       @default(0)
  createdAt   DateTime  @default(now())

  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([paymentId])
  @@index([receiptNumber])
  @@map("payment_receipts")
}

// ─── Payment Audit Trail ──────────────────────────────────────────
// Every action on a payment: create, revert, modify, print.
model PaymentAuditLog {
  id              String   @id @default(uuid())
  paymentId       String
  action          String // CREATED | REVERTED | REPRINTED | DOWNLOADED | MODIFIED
  previousValue   Json? // Payment state before change
  newValue        Json? // Payment state after change
  performedById   String
  performedByName String? // Denormalized for audit readability
  ipAddress       String?
  userAgent       String?
  createdAt       DateTime @default(now())

  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([paymentId, createdAt])
  @@index([performedById, createdAt])
  @@map("payment_audit_logs")
}
