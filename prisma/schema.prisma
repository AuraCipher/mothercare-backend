// Mother Care — School Management Platform
// Database Schema v2.0 — Academic Year System
// PostgreSQL + Prisma ORM

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ╔══════════════════════════════════════════════════════════════════╗
// ║                         ENUMERATIONS                            ║
// ╚══════════════════════════════════════════════════════════════════╝

enum Role {
  super_admin // Highest authority, full system access
  management // Administrative staff with assigned permissions
  teacher // Class/group instructors
  parent // Parent/student merged account
  student // Student login account
}

enum Gender {
  male
  female
  other
}

enum AccountStatus {
  active
  inactive
  suspended
}

// Branch-level roles for hierarchical access control
enum BranchRole {
  branch_admin // Principal — full branch management
  sub_admin // Vice-Principal / Deputy
  management // Accountant, Admin Staff
  teacher // Teaching staff
  parent // Parent representative
}

// Academic Year lifecycle: BUILD_STAGE → ACTIVE → ARCHIVED
enum AcademicYearStatus {
  BUILD_STAGE // Year being set up — only admins see it
  ACTIVE // Current operational year — everyone sees it
  ON_HOLD // Temporarily paused (e.g. summer break) — resume to ACTIVE
  ARCHIVED // Closed year — admins can still edit data
}

// Year-end close / batch promotion state machine
enum PromotionStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  REVERSED
  FAILED
}

// Student lifecycle status
enum StudentStatus {
  ACTIVE
  GRADUATED
  WITHDRAWN
  TRANSFERRED
  SUSPENDED
  EXPELED
  DECEASED
}

enum ApiKeyType {
  publishable // Public: verified store / registered layout
  secret // Admin: bypass login, full CRUD
}

// ╔══════════════════════════════════════════════════════════════════╗
// ║                           USERS                                 ║
// ║  All credentials created by admin. No signup / forgot password. ║
// ╚══════════════════════════════════════════════════════════════════╝

model User {
  id               String        @id @default(uuid())
  schoolId         String?
  name             String
  username         String?       @unique
  email            String?       @unique
  phone            String?       @unique
  passwordHash     String
  role             Role          @default(parent)
  managementPerms  String[]      @default([])
  gender           Gender?
  dateOfBirth      DateTime?
  address          String?
  profilePhoto     String?
  profilePhotoId   String?       @unique
  profileFile      FileRecord?   @relation("UserProfilePhoto", fields: [profilePhotoId], references: [id])
  status           AccountStatus @default(active)
  isEmailVerified  Boolean       @default(false)
  isPhoneVerified  Boolean       @default(false)
  lastLoginAt      DateTime?
  lastSeen         DateTime?
  rememberMeToken  String?       @unique
  rememberMeExpiry DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  // Existing relations
  managementProfile   ManagementProfile?
  teacherProfile      TeacherProfile?
  parentProfile       ParentProfile?
  subjectsAsHod       Subject[]               @relation("SubjectHOD")
  sentMessages        Message[]               @relation("SentMessages")
  notifications       NotificationRecipient[]
  deviceTokens        DeviceToken[]
  auditLogs           AuditLog[]
  groupMembers        GroupMember[]
  batchPromotions     BatchPromotion[]        @relation("PromotedByUser")
  passwordResetTokens PasswordResetToken[]

  // New relations for Academic Year System
  branchMembers         BranchMember[]
  // Reverse relations for BranchMember.assignedBy and BranchMember.resignedInFavorOf
  assignedMembers       BranchMember[]         @relation("AssignedBy")
  resignedToMembers     BranchMember[]         @relation("ResignedInFavorOf")
  academicYearMembers   AcademicYearMember[]
  teacherAssignments    TeacherAssignment[]
  teacherAttendances    TeacherAttendance[] @relation("TeacherAttendanceTeacher")
  academicYearSnapshots AcademicYearSnapshot[] @relation("SnapshotTriggeredBy")
  timetableEntries      TimetableEntry[]       @relation("TimetableTeacher")
  uploadedFiles         FileRecord[]
  student               Student?
  createdStudents       Student[]  @relation("StudentCreatedBy")
  updatedStudents       Student[]  @relation("StudentUpdatedBy")
  credentialSends       CredentialSend[]
  markedAttendances         Attendance[]
  teacherAttendanceMarkedBy TeacherAttendance[] @relation("TeacherAttendanceMarkedBy")
  studentStatusChanges      StudentStatusLog[]
  feeChangeLogs             FeeChangeLog[]
  recordedPayments          Payment[]         @relation("PaymentRecordedBy")
  revertedPayments          Payment[]         @relation("PaymentRevertedBy")
  recordedFamilyPayments    FamilyPayment[]

  @@index([username])
  @@index([email])
  @@index([phone])
  @@index([role])
  @@index([status])
  @@map("users")
}

// ╔══════════════════════════════════════════════════════════════════╗
// ║                    FILE RECORD                                 ║
// ║  Universal file reference for profile photos, documents, etc.  ║
// ╚══════════════════════════════════════════════════════════════════╝

model FileRecord {
  id           String   @id @default(uuid())
  originalName String
  storagePath  String   @unique
  mimeType     String
  size         Int
  width        Int?
  height       Int?
  uploadedById String?
  entityType   String? // "student" | "teacher" — what entity this doc belongs to
  entityId     String? // UUID of the student or teacher profile
  createdAt    DateTime @default(now())

  uploader       User?    @relation(fields: [uploadedById], references: [id])
  profileUser    User?    @relation("UserProfilePhoto")
  profileStudent Student? @relation("StudentProfilePhoto")

  updatedAt       DateTime      @updatedAt

  @@index([entityType, entityId])
  @@map("file_records")

}

// ╔══════════════════════════════════════════════════════════════════╗
// ║                       SCHOOL / TENANT                           ║
// ║  Kept for backward compatibility (may be deprecated later).     ║
// ╚══════════════════════════════════════════════════════════════════╝

model School {
  id              String   @id @default(uuid())
  name            String
  address         String?
  phone           String?
  email           String?
  logoUrl         String?
  website         String?
  timezone        String   @default("Asia/Karachi")
  currency        String   @default("PKR")
  passingMarks    Float    @default(50.0)
  attendanceAlert Int      @default(75)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  createdById     String?
  updatedById     String?

  @@map("schools")

}

// ╔══════════════════════════════════════════════════════════════════╗
// ║                        BRANCH (Physical Campus)                 ║
// ║  A physical school campus or franchise location.               ║
// ║  Example: "Mother Care Sohan" (code: MCS-SOHAN)               ║
// ╚══════════════════════════════════════════════════════════════════╝

model Branch {
  id        String   @id @default(uuid())
  name      String   @unique
  code      String   @unique // Short code: "MCS-SOHAN"
  address   String?
  phone     String?
  email     String?
  logoUrl   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  academicYears    AcademicYear[]
  branchMembers    BranchMember[]
  adminInvitations AdminInvitation[]

  createdById     String?
  updatedById     String?

  @@map("branches")

}

// ╔══════════════════════════════════════════════════════════════════╗
// ║                   ACADEMIC CALENDAR                             ║
// ║  Shared reference: label ("2025-2026"), start/end dates.       ║
// ║  Decoupled from the container — multiple branches share the    ║
// ║  same calendar definition.                                     ║
// ╚══════════════════════════════════════════════════════════════════╝

model AcademicCalendar {
  id        String   @id @default(uuid())
  label     String   @unique // "2025-2026", "2026-2027"
  startDate DateTime
  endDate   DateTime
  isCurrent Boolean  @default(false) // Only one globally
  createdAt DateTime @default(now())

  academicYears AcademicYear[]

  updatedAt       DateTime      @updatedAt

  createdById     String?
  updatedById     String?

  @@map("academic_calendars")


}

// ╔══════════════════════════════════════════════════════════════════╗
// ║                      ACADEMIC YEAR                              ║
// ║  The core container — everything lives inside one.              ║
// ║  Lifecycle: BUILD_STAGE → ACTIVE → ARCHIVED                    ║
// ║  Exactly one ACTIVE per branch.                                 ║
// ╚══════════════════════════════════════════════════════════════════╝

model AcademicYear {
  id                     String             @id @default(uuid())
  branchId               String
  calendarId             String
  status                 AcademicYearStatus @default(BUILD_STAGE)
  previousAcademicYearId String? // Self-referencing FK for year chain
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt

  branch               Branch           @relation(fields: [branchId], references: [id], onDelete: Cascade)
  calendar             AcademicCalendar @relation(fields: [calendarId], references: [id])
  previousAcademicYear AcademicYear?    @relation("YearSequence", fields: [previousAcademicYearId], references: [id])
  nextAcademicYears    AcademicYear[]   @relation("YearSequence")

  members            AcademicYearMember[]
  groups             Group[]
  subjects           Subject[]
  teacherAssignments TeacherAssignment[]
  students           Student[]
  enrollments        Enrollment[]
  snapshots          AcademicYearSnapshot[] @relation("SourceAcademicYear")
  newSnapshots       AcademicYearSnapshot[] @relation("NewAcademicYear")
  announcements      Announcement[]
  timetables         Timetable[]
  attendances        Attendance[]
  teacherAttendances TeacherAttendance[]

  createdById     String?
  updatedById     String?

  @@unique([branchId, calendarId])
  feeStructures    FeeStructure[]
  studentFees      StudentFee[]

  @@map("academic_years")

}

// ╔══════════════════════════════════════════════════════════════════╗
// ║                   ACADEMIC YEAR MEMBER                          ║
// ║  Links users to an academic year with a specific role.          ║
// ╚══════════════════════════════════════════════════════════════════╝

model AcademicYearMember {
  id             String @id @default(uuid())
  academicYearId String
  userId         String
  role           Role

  academicYear AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  createdById     String?
  updatedById     String?

  @@unique([academicYearId, userId])
  @@map("academic_year_members")


}

// ╔══════════════════════════════════════════════════════════════════╗
// ║                       BRANCH MEMBER                             ║
// ║  Links users to a branch (cross-year membership).               ║
// ╚══════════════════════════════════════════════════════════════════╝

model BranchMember {
  id                  String     @id @default(uuid())
  branchId            String
  userId              String
  role                BranchRole @default(teacher)
  isActive            Boolean    @default(true)
  keepTeacherRole     Boolean    @default(true)
  assignedById        String?
  resignedAt          DateTime?
  resignedInFavorOfId String?
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt

  branch            Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)
  user              User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignedBy        User?  @relation("AssignedBy", fields: [assignedById], references: [id])
  resignedInFavorOf User?  @relation("ResignedInFavorOf", fields: [resignedInFavorOfId], references: [id])

  createdById     String?
  updatedById     String?

  @@unique([branchId, userId])
  @@index([userId])
  @@map("branch_members")

}

// ╔══════════════════════════════════════════════════════════════════╗
// ║                     GROUPS (CLASSES / SECTIONS)                 ║
// ║  Represents a class + section within an academic year.          ║
// ║  Examples: "Playgroup", "Class 3-A", "Class 10-Bio"            ║
// ╚══════════════════════════════════════════════════════════════════╝

model Group {
  id               String   @id @default(uuid())
  academicYearId   String
  name             String // "Playgroup", "Class 3", "Class 10"
  section          String? // "A", "B" or "Bio", "CompSci", "Arts"
  displayOrder     Int // 1-13 for ordering/grade level
  capacity         Int      @default(30)
  onlyAdminCanSend Boolean  @default(true)
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  academicYear       AcademicYear        @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  members            GroupMember[]
  messages           Message[]
  students           Student[]
  groupSubjects      GroupSubject[]
  teacherAssignments TeacherAssignment[]
  enrollments        Enrollment[]
  timetableEntries   TimetableEntry[]

  createdById     String?
  updatedById     String?

  @@unique([academicYearId, name, section])
  feeStructures    FeeStructure[]
  studentFees      StudentFee[]

  @@map("groups")

}

// Group membership (users in a group)
model GroupMember {
  id       String   @id @default(uuid())
  groupId  String
  userId   String
  role     Role
  joinedAt DateTime @default(now())

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  createdById     String?
  updatedById     String?

  @@unique([groupId, userId])
  @@map("group_members")


}

// ╔══════════════════════════════════════════════════════════════════╗
// ║                      SUBJECT                                    ║
// ║  Subjects exist at the AcademicYear level and are linked to     ║
// ║  specific groups via GroupSubject. One definition can be shared ║
// ║  across multiple groups/sections.                               ║
// ╚══════════════════════════════════════════════════════════════════╝

model Subject {
  id             String   @id @default(uuid())
  academicYearId String
  name           String // "English", "Mathematics", "Science"
  code           String? // Optional subject code (unique per AY)
  description    String?
  totalMarks     Float    @default(100)
  passingMarks   Float    @default(50)
  isElective     Boolean  @default(false)
  hodId          String? // Head of Department — FK to User
  createdAt      DateTime @default(now())

  academicYear       AcademicYear        @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  groupSubjects      GroupSubject[]
  teacherAssignments TeacherAssignment[]
  timetableEntries   TimetableEntry[]
  hod                User?               @relation("SubjectHOD", fields: [hodId], references: [id])

  updatedAt       DateTime      @updatedAt

  createdById     String?
  updatedById     String?

  @@unique([academicYearId, code])
  @@map("subjects")


}

// ╔══════════════════════════════════════════════════════════════════╗
// ║                    GROUP-SUBJECT LINKING                        ║
// ║  Links a subject to a specific group within an academic year.   ║
// ║  Enables sharing "English" across Class 1-A and Class 1-B.     ║
// ╚══════════════════════════════════════════════════════════════════╝

model GroupSubject {
  id        String @id @default(uuid())
  groupId   String
  subjectId String

  group   Group   @relation(fields: [groupId], references: [id], onDelete: Cascade)
  subject Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  createdById     String?
  updatedById     String?

  @@unique([groupId, subjectId])
  @@map("group_subjects")


}

// ╔══════════════════════════════════════════════════════════════════╗
// ║                     TEACHER PROFILE                             ║
// ║  Detailed profile for teacher role users.                       ║
// ╚══════════════════════════════════════════════════════════════════╝

model TeacherProfile {
  id               String    @id @default(uuid())
  userId           String    @unique
  employeeId       String?   @unique
  qualification    String?
  specialization   String?
  joiningDate      DateTime?
  salary           Decimal?  @db.Decimal(12, 2)
  phone            String?
  emergencyContact String?
  address          String?
  dateOfBirth      DateTime?
  gender           Gender?
  bloodGroup       String?
  fatherName       String?
  cardId           String?
  severeDisease    String?
  experience       String?
  bio              String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdById         String?
  updatedById         String?
  credentialGeneratedAt  DateTime?
  credentialSentAt       DateTime?
  credentialDeliveredAt  DateTime?
  credentialSeenAt       DateTime?
  passwordSetAt          DateTime?
  credentialStatus       String?       @default("none")

  @@map("teacher_profiles")

}

// ╔══════════════════════════════════════════════════════════════════╗
// ║                    TEACHER ASSIGNMENT                           ║
// ║  Assigns a teacher to teach a specific subject in a specific    ║
// ║  group during an academic year. isClassTeacher marks the homeroom ║
// ║  teacher for that group.                                        ║
// ╚══════════════════════════════════════════════════════════════════╝

model TeacherAssignment {
  id             String  @id @default(uuid())
  academicYearId String
  teacherId      String // FK → User (role=teacher)
  groupId        String
  subjectId      String
  isClassTeacher Boolean @default(false)
  role           String  @default("primary") // "primary", "assistant", "hod"

  academicYear AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  teacher      User         @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  group        Group        @relation(fields: [groupId], references: [id], onDelete: Cascade)
  subject      Subject      @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  createdById     String?
  updatedById     String?

  @@map("teacher_assignments")


}

// ╔══════════════════════════════════════════════════════════════════╗
// ║                    MANAGEMENT PROFILE                           ║
// ║  Track admin/management staff details.                         ║
// ╚══════════════════════════════════════════════════════════════════╝

model ManagementProfile {
  id          String    @id @default(uuid())
  userId      String    @unique
  employeeId  String?   @unique
  department  String?
  designation String?
  permissions String[]  @default([])
  joiningDate DateTime?
  salary      Decimal?  @db.Decimal(12, 2)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdById     String?
  updatedById     String?

  @@map("management_profiles")

}

// ╔══════════════════════════════════════════════════════════════════╗
// ║                      PARENT PROFILE                             ║
// ╚══════════════════════════════════════════════════════════════════╝

model ParentProfile {
  id            String   @id @default(uuid())
  userId        String   @unique
  occupation    String?
  employerName  String?
  maritalStatus String?
  monthlyIncome String?
  relation      String? // "Father", "Mother", "Guardian"
  cnicNumber    String?  @unique
  phone         String?
  whatsapp      String?
  email         String?
  createdAt     DateTime @default(now())

  user     User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  children StudentParent[]

  updatedAt       DateTime      @updatedAt

  createdById     String?
  updatedById     String?

  @@map("parent_profiles")


}

// ╔══════════════════════════════════════════════════════════════════╗
// ║                          STUDENT                                ║
// ║  Core student record. Current placement is groupId. Full        ║
// ║  history tracked via Enrollment model.                          ║
// ╚══════════════════════════════════════════════════════════════════╝

model Student {
  id              String        @id @default(uuid())
  academicYearId  String
  groupId         String?
  familyId        String?
  name            String
  rollNumber      String?
  admissionNumber String?       @unique
  dateOfBirth     DateTime?
  gender          Gender?
  religion        String?
  nationality     String?       @default("Pakistani")
  customFeeAmount Int?          // Per-student fee override (paise). Null = use class structure.
  concessionReason String?        // Reason: scholarship, discount, teachers child, etc.
  address         String?
  phone           String?
  bloodGroup      String?
  bformCnic       String?
  motherTongue    String?
  studentEmail    String?
  studentWhatsapp String?
  city            String?
  postalCode      String?
  country         String?
  previousSchool  String?
  previousClass   String?
  tcNumber        String?
  referredBy      String?
  profilePhotoId  String?       @unique
  profileFile     FileRecord?   @relation("StudentProfilePhoto", fields: [profilePhotoId], references: [id])
  userId          String?       @unique
  user            User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  username        String?
  studentNumber   Int?          @unique
  status          StudentStatus @default(ACTIVE)
  isActive        Boolean       @default(true)
  admissionDate   DateTime      @default(now())
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  createdById     String?
  updatedById     String?
  createdBy       User?         @relation("StudentCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy       User?         @relation("StudentUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  credentialGeneratedAt  DateTime?
  credentialSentAt       DateTime?
  credentialDeliveredAt  DateTime?
  credentialSeenAt       DateTime?
  passwordSetAt          DateTime?
  credentialStatus       String?       @default("none")
  credentialSends        CredentialSend[]
  statusLogs             StudentStatusLog[]
  attendanceNotifications AttendanceNotification[]

  academicYear      AcademicYear       @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  group             Group?             @relation(fields: [groupId], references: [id], onDelete: SetNull)
  family            Family?            @relation("StudentFamily", fields: [familyId], references: [id], onDelete: SetNull)
  parents           StudentParent[]
  enrollments       Enrollment[]
  emergencyContacts EmergencyContact[]
  healthRecord      HealthRecord?
  attendances       Attendance[]
  studentFees       StudentFee[]
  feePayments       Payment[]     @relation("PaymentStudent")

  @@index([groupId])
  @@index([familyId])
  @@index([academicYearId])
  @@map("students")
}

// ─── Attendance (one row per student per day per AY) ─────────
model Attendance {
  id             String   @id @default(uuid())
  studentId      String
  academicYearId String
  date           DateTime @db.Date
  status         String   // "present" | "absent" | "late" | "leave" | "holiday" | "function"
  note           String?
  markedById     String?

  student      Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  academicYear AcademicYear @relation(fields: [academicYearId], references: [id])
  markedBy     User?        @relation(fields: [markedById], references: [id])

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([studentId, date])
  @@index([academicYearId, date])
  @@map("attendances")
}

model TeacherAttendance {
  id             String   @id @default(uuid())
  teacherId      String
  academicYearId String
  date           DateTime @db.Date
  status         String   // "present" | "absent" | "late" | "leave" | "holiday" | "function"
  note           String?
  markedById     String?

  teacher      User         @relation("TeacherAttendanceTeacher", fields: [teacherId], references: [id], onDelete: Cascade)
  academicYear AcademicYear @relation(fields: [academicYearId], references: [id])
  markedBy     User?        @relation("TeacherAttendanceMarkedBy", fields: [markedById], references: [id])

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([teacherId, date])
  @@index([academicYearId, date])
  @@map("teacher_attendances")
}

// Credential send history (redacted — no passwords stored)
model CredentialSend {
  id          String   @id @default(uuid())
  studentId   String
  sentAt      DateTime @default(now())
  deliveredAt DateTime?
  seenAt      DateTime?
  status      String   // "sent" | "delivered" | "read" | "failed"
  to          String?  // Masked phone: "03XX-XXXXXX"
  errorMsg    String?
  sentById    String?

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  sentBy  User?   @relation(fields: [sentById], references: [id])

  @@index([studentId])
  @@map("credential_sends")
}

// Student-Parent linking (many-to-many)
model StudentParent {
  id        String   @id @default(uuid())
  studentId String
  parentId  String
  relation  String // "Father", "Mother", "Guardian"
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())

  student Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  parent  ParentProfile @relation(fields: [parentId], references: [id], onDelete: Cascade)

  updatedAt       DateTime      @updatedAt

  createdById     String?
  updatedById     String?

  @@unique([studentId, parentId])
  @@map("student_parents")


}

// ╔══════════════════════════════════════════════════════════════════╗
// ║                    EMERGENCY CONTACT                             ║
// ╚══════════════════════════════════════════════════════════════════╝

model EmergencyContact {
  id           String   @id @default(uuid())
  studentId    String
  name         String
  relationship String
  phone        String
  whatsapp     String?
  priority     Int      @default(1)
  createdAt    DateTime @default(now())

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  updatedAt       DateTime      @updatedAt

  createdById     String?
  updatedById     String?

  @@map("emergency_contacts")


}

// ╔══════════════════════════════════════════════════════════════════╗
// ║                      HEALTH RECORD                              ║
// ║  One record per student.                                        ║
// ╚══════════════════════════════════════════════════════════════════╝

model HealthRecord {
  id                String   @id @default(uuid())
  studentId         String   @unique
  bloodGroup        String?
  hasChronicDisease Boolean  @default(false)
  diseaseDetails    String?
  allergies         String?
  disability        String?
  medicalNotes      String?
  doctorName        String?
  doctorPhone       String?
  updatedAt         DateTime @updatedAt

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  createdAt       DateTime      @default(now())

  createdById     String?
  updatedById     String?

  @@map("health_records")


}

// ╔══════════════════════════════════════════════════════════════════╗
// ║                       ENROLLMENT                                ║
// ║  One record per student per academic year. Immutable after      ║
// ║  creation (only leftAt can be set at year-end close).           ║
// ╚══════════════════════════════════════════════════════════════════╝

model Enrollment {
  id             String    @id @default(uuid())
  studentId      String
  academicYearId String
  groupId        String
  rollNumber     String?
  joinedAt       DateTime  @default(now())
  leftAt         DateTime?

  student      Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  academicYear AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  group        Group        @relation(fields: [groupId], references: [id], onDelete: Cascade)

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  createdById     String?
  updatedById     String?

  @@unique([studentId, academicYearId])
  @@map("enrollments")


}

// ╔══════════════════════════════════════════════════════════════════╗
// ║                    ACADEMIC YEAR SNAPSHOT                       ║
// ║  Records a year-end close / batch promotion event. Contains     ║
// ║  frozen snapshot of all groups within the academic year.        ║
// ╚══════════════════════════════════════════════════════════════════╝

model AcademicYearSnapshot {
  id                String          @id @default(uuid())
  academicYearId    String
  newAcademicYearId String?
  fromLabel         String // Human label of source year
  toLabel           String // Human label of target year
  triggeredById     String // User who triggered the close
  status            PromotionStatus @default(PENDING)
  totalStudents     Int             @default(0)
  totalGraduated    Int             @default(0)
  canReverse        Boolean         @default(true)
  reversedAt        DateTime?
  createdAt         DateTime        @default(now())

  academicYear    AcademicYear    @relation("SourceAcademicYear", fields: [academicYearId], references: [id], onDelete: Cascade)
  newAcademicYear AcademicYear?   @relation("NewAcademicYear", fields: [newAcademicYearId], references: [id])
  triggeredBy     User            @relation("SnapshotTriggeredBy", fields: [triggeredById], references: [id])
  groupSnapshots  GroupSnapshot[]

  updatedAt       DateTime      @updatedAt

  createdById     String?
  updatedById     String?

  @@map("academic_year_snapshots")


}

// ╔══════════════════════════════════════════════════════════════════╗
// ║                      GROUP SNAPSHOT                             ║
// ║  Frozen state of a group at year-end close time.                ║
// ║  studentsData and teachersData are JSON snapshots.              ║
// ╚══════════════════════════════════════════════════════════════════╝

model GroupSnapshot {
  id           String  @id @default(uuid())
  snapshotId   String
  groupId      String // Original group ID (not FK — group may change)
  groupName    String
  section      String?
  displayOrder Int
  studentsData Json? // Frozen student list
  teachersData Json? // Frozen teacher assignments
  studentCount Int     @default(0)

  snapshot AcademicYearSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  createdById     String?
  updatedById     String?

  @@map("group_snapshots")


}

// ╔══════════════════════════════════════════════════════════════════╗
// ║                    ANNOUNCEMENTS                                ║
// ╚══════════════════════════════════════════════════════════════════╝

model Announcement {
  id             String   @id @default(uuid())
  academicYearId String
  senderId       String
  title          String
  content        String?
  mediaUrl       String?
  isPinned       Boolean  @default(false)
  createdAt      DateTime @default(now())

  academicYear AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)

  updatedAt       DateTime      @updatedAt

  @@index([academicYearId, createdAt])
  @@map("announcements")

}

// ╔══════════════════════════════════════════════════════════════════╗
// ║                     MESSAGES (GROUP CHAT)                       ║
// ╚══════════════════════════════════════════════════════════════════╝

model Message {
  id        String   @id @default(uuid())
  groupId   String
  senderId  String
  content   String?
  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  group  Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  sender User  @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([groupId, createdAt])
  @@map("messages")
}

// Attendance notifications for parents (queued for chat app pickup)
model AttendanceNotification {
  id          String   @id @default(uuid())
  studentId   String
  date        DateTime @db.Date
  status      String
  message     String
  sent        Boolean  @default(false)
  sentAt      DateTime?
  createdAt   DateTime @default(now())

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([sent])
  @@map("attendance_notifications")
}

// ╔══════════════════════════════════════════════════════════════════╗
// ║                    BATCH PROMOTION                              ║
// ║  Promote all students from current class to next.              ║
// ║  Will be fully reworked in Phase 12.                           ║
// ╚══════════════════════════════════════════════════════════════════╝

model BatchPromotion {
  id             String    @id @default(uuid())
  academicYearId String
  fromYear       String
  toYear         String
  promotedById   String
  status         String    @default("pending")
  totalStudents  Int
  canReverse     Boolean   @default(true)
  reversedAt     DateTime?
  notes          String?
  createdAt      DateTime  @default(now())

  promotedBy User @relation("PromotedByUser", fields: [promotedById], references: [id])

  updatedAt       DateTime      @updatedAt

  createdById     String?
  updatedById     String?

  @@map("batch_promotions")


}

// ╔══════════════════════════════════════════════════════════════════╗
// ║                    NOTIFICATION SYSTEM                          ║
// ╚══════════════════════════════════════════════════════════════════╝

model NotificationRecipient {
  id        String    @id @default(uuid())
  userId    String
  title     String
  body      String
  type      String // "announcement", "message", etc.
  data      Json?
  isRead    Boolean   @default(false)
  readAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  updatedAt       DateTime      @updatedAt

  @@index([userId, isRead])
  @@map("notification_recipients")

}

// Device tokens for push notifications
model DeviceToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  platform  String // "android", "ios", "web"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("device_tokens")
}

// ╔══════════════════════════════════════════════════════════════════╗
// ║                    PASSWORD RESET TOKENS                        ║
// ╚══════════════════════════════════════════════════════════════════╝

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id])

  updatedAt       DateTime      @updatedAt

  @@index([token])
  @@map("password_reset_tokens")

}

// ╔══════════════════════════════════════════════════════════════════╗
// ║                       AUDIT TRAIL                               ║
// ╚══════════════════════════════════════════════════════════════════╝

model AuditLog {
  id        String   @id @default(uuid())
  userId    String
  action    String
  entity    String
  entityId  String?
  oldValue  Json?
  newValue  Json?
  ipAddress String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  updatedAt       DateTime      @updatedAt

  @@index([userId, createdAt])
  @@index([entity, entityId])
  @@map("audit_logs")

}

// ╔══════════════════════════════════════════════════════════════════╗
// ║                         API KEYS                                ║
// ╚══════════════════════════════════════════════════════════════════╝

model ApiKey {
  id         String     @id @default(uuid())
  name       String
  type       ApiKeyType @default(publishable)
  keyHash    String     @unique
  prefix     String // e.g. "mcs_abc1"
  createdBy  String
  lastUsedAt DateTime?
  expiresAt  DateTime?
  revokedAt  DateTime?
  createdAt  DateTime   @default(now())

  updatedAt       DateTime      @updatedAt

  @@index([prefix])
  @@index([revokedAt])
  @@index([type])
  @@map("api_keys")

}

// ╔══════════════════════════════════════════════════════════════════╗
// ║                     ADMIN INVITATIONS                           ║
// ╚══════════════════════════════════════════════════════════════════╝

model AdminInvitation {
  id        String    @id @default(uuid())
  email     String
  name      String?
  phone     String?
  branchId  String
  token     String    @unique
  usedAt    DateTime?
  expiresAt DateTime
  createdAt DateTime  @default(now())

  branch Branch @relation(fields: [branchId], references: [id])

  updatedAt       DateTime      @updatedAt

  createdById     String?
  updatedById     String?

  @@index([token])
  @@index([email])
  @@index([branchId])
  @@map("admin_invitations")


}

// ╔══════════════════════════════════════════════════════════════════╗
// ║                   TIMETABLE SLOTS                               ║
// ║  Universal time grid for all classes within an academic year.  ║
// ║  Defines the lecture periods (start-end time) for each day.    ║
// ╚══════════════════════════════════════════════════════════════════╝

// ╔══════════════════════════════════════════════════════════════════╗
// ║              TIMETABLE (parent entity)                          ║
// ║  Each timetable/datesheet has its own ID, name, type.          ║
// ║  Slots, day configs, and entries all reference this ID.        ║
// ╚══════════════════════════════════════════════════════════════════╝

model Timetable {
  id             String   @id @default(uuid())
  academicYearId String
  name           String // Display name (regular, friday-schedule, exam-week)
  type           String   @default("timetable") // "timetable" or "datesheet"
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())

  academicYear AcademicYear         @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  slots        TimetableSlot[]
  dayConfigs   TimetableDayConfig[]

  updatedAt       DateTime      @updatedAt

  createdById     String?
  updatedById     String?

  @@unique([academicYearId, name])
  @@map("timetables")


}

model TimetableSlot {
  id            String   @id @default(uuid())
  timetableId   String
  dayOfWeek     Int? // null = all days, 1=Monday ... 6=Saturday
  lectureNumber Int // 1, 2, 3...
  startTime     String // "08:00"
  endTime       String // "08:40"
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())

  timetable Timetable        @relation(fields: [timetableId], references: [id], onDelete: Cascade)
  entries   TimetableEntry[]

  updatedAt       DateTime      @updatedAt

  createdById     String?
  updatedById     String?

  @@unique([timetableId, lectureNumber])
  @@map("timetable_slots")


}

// ╔══════════════════════════════════════════════════════════════════╗
// ║                   TIMETABLE ENTRIES                             ║
// ║  Links a slot → section → subject + teacher.                   ║
// ║  One entry per slot per section.                               ║
// ╚══════════════════════════════════════════════════════════════════╝

model TimetableEntry {
  id        String  @id @default(uuid())
  slotId    String
  groupId   String // FK → Group (section)
  subjectId String?
  teacherId String?
  note      String? // "break", etc.

  slot    TimetableSlot @relation(fields: [slotId], references: [id], onDelete: Cascade)
  group   Group         @relation(fields: [groupId], references: [id], onDelete: Cascade)
  subject Subject?      @relation(fields: [subjectId], references: [id])
  teacher User?         @relation("TimetableTeacher", fields: [teacherId], references: [id])

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  createdById     String?
  updatedById     String?

  @@unique([slotId, groupId])
  @@map("timetable_entries")


}

// ╔══════════════════════════════════════════════════════════════════╗
// ║              TIMETABLE DAY CONFIG                               ║
// ║  Stores which days are active per timetable.                   ║
// ╚══════════════════════════════════════════════════════════════════╝

model TimetableDayConfig {
  id          String   @id @default(uuid())
  timetableId String
  dayOfWeek   Int // 1=Mon ... 6=Sat
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  timetable Timetable @relation(fields: [timetableId], references: [id], onDelete: Cascade)

  updatedAt       DateTime      @updatedAt

  createdById     String?
  updatedById     String?

  @@unique([timetableId, dayOfWeek])
  @@map("timetable_day_configs")


}

// ╔══════════════════════════════════════════════════════════════════╗
// ║                    STUDENT STATUS LOG                            ║
// ║  Tracks every status change with reason and who changed it.     ║
// ╚══════════════════════════════════════════════════════════════════╝

model StudentStatusLog {
  id              String        @id @default(uuid())
  studentId       String
  previousStatus  StudentStatus?
  newStatus       StudentStatus
  reason          String?
  changedById     String?
  createdAt       DateTime      @default(now())

  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  changedBy User?   @relation(fields: [changedById], references: [id])

  @@index([studentId])
  @@map("student_status_logs")
}

// ╔══════════════════════════════════════════════════════════════════╗
// ║                     FEE / PAYMENT SYSTEM                        ║
// ║  Family grouping, fee heads, structures, student fees,          ║
// ║  payments, receipts, and sibling combined payments.             ║
// ╚══════════════════════════════════════════════════════════════════╝

model Family {
  id         String    @id @default(uuid())
  name       String?
  fatherName String?
  motherName String?
  phone      String?
  address    String?
  createdAt  DateTime  @default(now())

  students Student[]       @relation("StudentFamily")
  payments FamilyPayment[]

  @@map("families")
}

model FeeHead {
  id          String   @id @default(uuid())
  name        String   // Tuition, Transport, Lab, Library, etc.
  description String?
  isOptional  Boolean  @default(false)
  isActive    Boolean  @default(true)
  category    String   @default("MONTHLY") // MONTHLY | TERM | ANNUAL | ONE_TIME
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  structures FeeStructure[]

  @@map("fee_heads")
}

model FeeStructure {
  id             String    @id @default(uuid())
  academicYearId String
  groupId        String
  feeHeadId      String
  amount         Int       // In paise (500000 = 5000 PKR)
  effectiveFrom  DateTime  @default(now())
  effectiveTo    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  academicYear AcademicYear @relation(fields: [academicYearId], references: [id])
  group        Group        @relation(fields: [groupId], references: [id])
  feeHead      FeeHead      @relation(fields: [feeHeadId], references: [id])
  changeLogs   FeeChangeLog[]

  @@unique([academicYearId, groupId, feeHeadId, effectiveFrom])
  @@index([academicYearId, groupId])
  @@map("fee_structures")
}

model FeeChangeLog {
  id             String   @id @default(uuid())
  feeStructureId String
  previousAmount Int
  newAmount      Int
  reason         String?
  changedById    String
  changedAt      DateTime @default(now())

  feeStructure FeeStructure @relation(fields: [feeStructureId], references: [id])
  changedBy    User         @relation(fields: [changedById], references: [id])

  @@index([feeStructureId])
  @@map("fee_change_logs")
}

model StudentFee {
  id             String   @id @default(uuid())
  academicYearId String
  studentId      String
  groupId        String?  // Snapshot of class at generation time
  month          Int      // 1-12
  year           Int
  totalAmount    Int      // Sum of all applicable heads (paise)
  concession     Int      @default(0)
  lateFee        Int      @default(0)
  netAmount      Int      // totalAmount - concession + lateFee
  paidAmount     Int      @default(0)
  status         String   @default("UNPAID") // UNPAID | PARTIAL | PAID | OVERPAID | WAIVED
  dueDate        DateTime?
  paidAt         DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  academicYear AcademicYear @relation(fields: [academicYearId], references: [id])
  student      Student      @relation(fields: [studentId], references: [id])
  group        Group?       @relation(fields: [groupId], references: [id])
  payments     Payment[]

  @@unique([studentId, month, year])
  @@index([month, year, status])
  @@index([academicYearId, status])
  @@map("student_fees")
}

model FamilyPayment {
  id            String    @id @default(uuid())
  familyId      String
  receiptNumber String    @unique // FMP-YYYYMM-XXXX
  totalAmount   Int
  paymentDate   DateTime  @default(now())
  recordedById  String
  createdAt     DateTime  @default(now())

  family   Family    @relation(fields: [familyId], references: [id])
  payments Payment[]
  recordedBy User    @relation(fields: [recordedById], references: [id])

  @@index([familyId])
  @@map("family_payments")
}

model Payment {
  id              String    @id @default(uuid())
  studentFeeId    String
  studentId       String
  familyPaymentId String?
  amount          Int       // In paise
  paymentMethod   String    // CASH | CHEQUE | BANK_TRANSFER
  receiptNumber   String    @unique // RCP-YYYYMM-XXXX
  reference       String?   // Cheque number / transaction ID
  paymentDate     DateTime  @default(now())
  recordedById    String
  note            String?
  revertedAt      DateTime?
  revertedById    String?
  revertReason    String?
  createdAt       DateTime  @default(now())

  studentFee    StudentFee     @relation(fields: [studentFeeId], references: [id])
  student       Student        @relation("PaymentStudent", fields: [studentId], references: [id], onDelete: Cascade)
  familyPayment FamilyPayment? @relation(fields: [familyPaymentId], references: [id])
  recordedBy    User           @relation("PaymentRecordedBy", fields: [recordedById], references: [id])
  revertedBy    User?          @relation("PaymentRevertedBy", fields: [revertedById], references: [id])

  @@index([studentFeeId])
  @@index([familyPaymentId])
  @@index([receiptNumber])
  @@index([studentId])
  @@map("payments")
}
